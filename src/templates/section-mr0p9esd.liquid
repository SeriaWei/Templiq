<!-- 场景模式展示 -->
{% header %}
<style>
.section-mr0p9esd {
    position: relative;
    padding: 92px 0 98px;
    background: #17130f;
    color: #fff3dc;
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
}
.section-mr0p9esd .la-scenes__intro {
    margin-bottom: 36px;
}
.section-mr0p9esd .la-scenes__kicker {
    margin: 0 0 20px;
    color: #ffba5d;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-mr0p9esd .la-scenes__title {
    margin: 0;
    font-family: Didot, "Bodoni 72", Georgia, serif;
    font-size: 52px;
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
}
.section-mr0p9esd .la-scenes__text {
    margin: 8px 0 0;
    color: rgba(255, 243, 220, 0.76);
    font-size: 18px;
    line-height: 1.8;
}
.section-mr0p9esd .la-scenes__grid {
    display: flex;
    flex-wrap: wrap;
}
.section-mr0p9esd .la-scenes__card {
    min-height: 280px;
    margin-bottom: 24px;
    padding: 28px;
    border: 1px solid rgba(255, 243, 220, 0.24);
    background: linear-gradient(160deg, rgba(255, 243, 220, 0.08), rgba(255, 243, 220, 0.02));
}
.section-mr0p9esd .la-scenes__card span {
    display: block;
    margin-bottom: 58px;
    color: #ffba5d;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 13px;
}
.section-mr0p9esd .la-scenes__card h3 {
    margin: 0 0 14px;
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 23px;
    font-weight: 600;
}
.section-mr0p9esd .la-scenes__card p {
    margin: 0;
    color: rgba(255, 243, 220, 0.72);
    font-size: 16px;
    line-height: 1.7;
}
.section-mr0p9esd .la-scenes__card--image {
    padding: 0;
    overflow: hidden;
    border-color: transparent;
}
.section-mr0p9esd .la-scenes__card--image img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.1);
}
@media (max-width: 767px) {
    .section-mr0p9esd {
        padding: 64px 0;
    }
    .section-mr0p9esd .la-scenes__title {
        font-size: 38px;
    }
}
</style>
{% endheader %}

<section class="section-mr0p9esd">
    <div class="container">
        <div class="row la-scenes__intro">
            <div class="col-md-5 col-sm-6">
                {% if this.Model.eyebrow %}
                <p class="la-scenes__kicker" property="true" data-property="eyebrow" method="text">{{this.Model.eyebrow}}</p>
                {% endif %}
                {% if this.Model.title %}
                <h2 class="la-scenes__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>
                {% endif %}
            </div>
            <div class="col-md-6 col-md-offset-1 col-sm-6">
                {% if this.Model.summary %}
                <p class="la-scenes__text" property="true" data-property="summary" method="text">{{this.Model.summary}}</p>
                {% endif %}
            </div>
        </div>
        {% if this.Model.scene_items %}
        <div class="row la-scenes__grid">
            {% for item in this.Model.scene_items %}
            <div class="col-md-3 col-sm-6">
                <article class="la-scenes__card{% if item.image != "" %} la-scenes__card--image{% endif %}">
                    {% if item.image != "" %}
                    <img property="true" data-property="scene_items[{{forloop.index0}}].image" method="attr" para="src" src="{% url item.image %}" alt="{{item.image_alt}}">
                    {% else %}
                    {% if item.number %}<span property="true" data-property="scene_items[{{forloop.index0}}].number" method="text">{{item.number}}</span>{% endif %}
                    {% if item.title %}<h3 property="true" data-property="scene_items[{{forloop.index0}}].title" method="text">{{item.title}}</h3>{% endif %}
                    {% if item.text %}<p property="true" data-property="scene_items[{{forloop.index0}}].text" method="text">{{item.text}}</p>{% endif %}
                    {% endif %}
                </article>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
