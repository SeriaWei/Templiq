<!-- 导航栏 -->
{% header %}
<style>
.section-mp9t3lxt {
  --sr-bg: #0e0b08;
  --sr-surface: #1a1612;
  --sr-surface-raised: #24201a;
  --sr-border: #332e27;
  --sr-text: #e8e2d8;
  --sr-text-secondary: #9c9488;
  --sr-accent-gold: #c9a84e;
  --sr-accent-gold-soft: rgba(201, 168, 78, 0.12);
  --sr-accent-ruby: #8b2f3f;
  --sr-font-heading: Georgia, "Times New Roman", Times, serif;
  --sr-font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --sr-font-mono: "SF Mono", "Fira Code", Consolas, monospace;
  font-size: 10px;
  background: var(--sr-bg);
  color: var(--sr-text);
  font-family: var(--sr-font-body);
  overflow-x: hidden;
}

.section-mp9t3lxt .sr-navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1000;
  padding: 16px 0;
  background: var(--sr-bg);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.section-mp9t3lxt .sr-navbar--scrolled {
  background: rgba(14, 11, 8, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(51, 46, 39, 0.5);
  padding: 8px 0;
}
.section-mp9t3lxt .sr-navbar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.section-mp9t3lxt .sr-navbar__brand {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: var(--sr-text);
  transition: color 0.3s;
}
.section-mp9t3lxt .sr-navbar__brand:hover {
  color: var(--sr-accent-gold);
  text-decoration: none;
}
.section-mp9t3lxt .sr-navbar__brand-icon { display: flex; align-items: center; color: var(--sr-accent-gold); }
.section-mp9t3lxt .sr-navbar__brand-text {
  font-family: var(--sr-font-heading);
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 0.06em;
}
.section-mp9t3lxt .sr-navbar__right { display: flex; align-items: center; gap: 32px; }
.section-mp9t3lxt .sr-navbar__links {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 4px;
}
.section-mp9t3lxt .sr-navbar__links li a {
  font-size: 13px;
  font-weight: 500;
  color: var(--sr-text-secondary);
  padding: 6px 14px;
  border-radius: 4px;
  transition: all 0.3s ease;
  text-decoration: none;
  letter-spacing: 0.03em;
  position: relative;
}
.section-mp9t3lxt .sr-navbar__links li a::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 14px;
  right: 14px;
  height: 1px;
  background: var(--sr-accent-gold);
  transform: scaleX(0);
  transition: transform 0.3s ease;
  transform-origin: center;
}
.section-mp9t3lxt .sr-navbar__links li a:hover,
.section-mp9t3lxt .sr-navbar__links li a.active { color: var(--sr-text); }
.section-mp9t3lxt .sr-navbar__links li a:hover::after,
.section-mp9t3lxt .sr-navbar__links li a.active::after { transform: scaleX(1); }
.section-mp9t3lxt .sr-navbar__cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--sr-bg);
  background: var(--sr-accent-gold);
  padding: 8px 20px;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}
.section-mp9t3lxt .sr-navbar__cta:hover {
  background: #dbb956;
  color: var(--sr-bg);
  text-decoration: none;
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(201, 168, 78, 0.3);
}
.section-mp9t3lxt .sr-navbar__toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 36px;
  height: 36px;
  background: none;
  border: 1px solid var(--sr-border);
  border-radius: 4px;
  cursor: pointer;
  padding: 8px;
  gap: 4px;
}
.section-mp9t3lxt .sr-navbar__toggle span {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--sr-text);
  border-radius: 1px;
  transition: all 0.3s ease;
}
.section-mp9t3lxt .sr-navbar__toggle.active span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
.section-mp9t3lxt .sr-navbar__toggle.active span:nth-child(2) { opacity: 0; }
.section-mp9t3lxt .sr-navbar__toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }
@media (max-width: 768px) {
  .section-mp9t3lxt .sr-navbar__toggle { display: flex; }
  .section-mp9t3lxt .sr-navbar__right {
    position: fixed;
    top: 0;
    right: -100%;
    width: 280px;
    height: 100vh;
    background: rgba(14, 11, 8, 0.98);
    backdrop-filter: blur(20px);
    border-left: 1px solid var(--sr-border);
    flex-direction: column;
    padding: 80px 24px 24px;
    gap: 24px;
    transition: right 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    align-items: stretch;
  }
  .section-mp9t3lxt .sr-navbar__right.open { right: 0; }
  .section-mp9t3lxt .sr-navbar__links { flex-direction: column; gap: 8px; }
  .section-mp9t3lxt .sr-navbar__links li a { display: block; padding: 10px 14px; font-size: 15px; }
  .section-mp9t3lxt .sr-navbar__cta { text-align: center; justify-content: center; }
}
</style>
{% endheader %}

<div class="section-mp9t3lxt">
<nav class="sr-navbar" id="srNavbar">
  <div class="container">
    <div class="sr-navbar__inner">
      <a href="#" class="sr-navbar__brand">
        <span class="sr-navbar__brand-icon">{{this.Model.brand_icon | raw}}</span>
        <span class="sr-navbar__brand-text" property="true" data-property="brand_text" method="text">{{this.Model.brand_text}}</span>
      </a>
      <button class="sr-navbar__toggle" id="srNavToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <div class="sr-navbar__right">
        <ul class="sr-navbar__links" id="srNavLinks">
          {% for link in this.Model.nav_links %}
          <li>
            <a property="true" data-property="nav_links[{{forloop.index0}}].href" method="attr" para="href" href="{% url link.href %}">{{link.text}}</a>
          </li>
          {% endfor %}
        </ul>
        {% if this.Model.cta_text %}
        <a property="true" data-property="cta_href" method="attr" para="href" href="{% url this.Model.cta_href %}" class="sr-navbar__cta">{{this.Model.cta_text}}</a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>

{% footer %}
<script type="text/javascript">
(function(){
  var navbar = document.getElementById('srNavbar');
  var navToggle = document.getElementById('srNavToggle');
  var navLinks = document.getElementById('srNavLinks');
  var navLinkItems = navLinks ? navLinks.querySelectorAll('a') : [];
  var navRight = document.querySelector('.sr-navbar__right');

  function handleNavScroll() {
    if (window.scrollY > 60) {
      navbar.classList.add('sr-navbar--scrolled');
    } else {
      navbar.classList.remove('sr-navbar--scrolled');
    }
  }
  window.addEventListener('scroll', handleNavScroll, { passive: true });
  handleNavScroll();

  if (navToggle) {
    navToggle.addEventListener('click', function () {
      navToggle.classList.toggle('active');
      navRight.classList.toggle('open');
    });
  }
  navLinkItems.forEach(function (link) {
    link.addEventListener('click', function () {
      navToggle.classList.remove('active');
      navRight.classList.remove('open');
    });
  });

  var sections = document.querySelectorAll('section[id]');
  var navAnchors = Array.from(navLinkItems);
  function updateActiveLink() {
    var scrollPos = window.scrollY + 120;
    sections.forEach(function (section) {
      var sectionTop = section.offsetTop;
      var sectionBottom = sectionTop + section.offsetHeight;
      var id = section.getAttribute('id');
      if (scrollPos >= sectionTop && scrollPos < sectionBottom) {
        navAnchors.forEach(function (a) {
          a.classList.remove('active');
          if (a.getAttribute('href') === '#' + id) {
            a.classList.add('active');
          }
        });
      }
    });
  }
  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
    anchor.addEventListener('click', function (e) {
      var targetId = this.getAttribute('href');
      if (targetId === '#') return;
      var target = document.querySelector(targetId);
      if (target) {
        e.preventDefault();
        window.scrollTo({ top: target.offsetTop - 80, behavior: 'smooth' });
      }
    });
  });
})();
</script>
{% endfooter %}
</div>
