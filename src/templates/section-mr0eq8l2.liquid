<!-- 咖啡机首屏 -->
{% header %}
<style>
.section-mr0eq8l2 {
    position: relative;
    min-height: 92vh;
    overflow: hidden;
    color: #fff8eb;
    background: #1b110b;
    font-family: "Avenir Next", "Gill Sans", "Microsoft YaHei", sans-serif;
    isolation: isolate;
}

.section-mr0eq8l2 .ab-hero__image {
    position: absolute;
    inset: 0;
    z-index: -3;
    transform: scale(1.03);
    animation: section-mr0eq8l2-abHeroDrift 16s ease-in-out infinite alternate;
}

.section-mr0eq8l2 .ab-hero__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.section-mr0eq8l2 .ab-hero__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(22, 14, 9, 0.88) 0%, rgba(39, 23, 14, 0.7) 46%, rgba(22, 14, 9, 0.22) 100%), radial-gradient(circle at 72% 22%, rgba(206, 129, 55, 0.45), transparent 32%), linear-gradient(180deg, rgba(10, 7, 5, 0.1), rgba(10, 7, 5, 0.56));
    z-index: -2;
}

.section-mr0eq8l2 .ab-hero__content {
    max-width: 760px;
    padding: 112px 0 76px;
}

.section-mr0eq8l2 .ab-hero__eyebrow {
    display: inline-block;
    margin-bottom: 24px;
    padding: 9px 16px;
    border: 1px solid rgba(255, 248, 235, 0.42);
    border-radius: 999px;
    color: #ffd79c;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: rgba(255, 248, 235, 0.08);
}

.section-mr0eq8l2 .ab-hero__title {
    margin: 0;
    font-family: Didot, "Bodoni 72", Georgia, "STSong", serif;
    font-size: 72px;
    line-height: 0.95;
    font-weight: 500;
    letter-spacing: 0;
}

.section-mr0eq8l2 .ab-hero__lead {
    max-width: 650px;
    margin: 28px 0 0;
    color: rgba(255, 248, 235, 0.82);
    font-size: 18px;
    line-height: 1.85;
}

.section-mr0eq8l2 .ab-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
}

.section-mr0eq8l2 .ab-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 3px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
}

.section-mr0eq8l2 .ab-hero__button:hover,
.section-mr0eq8l2 .ab-hero__button:focus {
    text-decoration: none;
    transform: translateY(-2px);
}

.section-mr0eq8l2 .ab-hero__button--solid {
    color: #24150e;
    background: #f2b15f;
    box-shadow: 0 18px 38px rgba(207, 116, 39, 0.34);
}

.section-mr0eq8l2 .ab-hero__button--line {
    border: 1px solid rgba(255, 248, 235, 0.42);
    color: #fff8eb;
    background: rgba(255, 248, 235, 0.06);
}

.section-mr0eq8l2 .ab-hero__metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    max-width: 650px;
    margin-top: 58px;
    border: 1px solid rgba(255, 248, 235, 0.22);
    background: rgba(255, 248, 235, 0.18);
}

.section-mr0eq8l2 .ab-hero__metric {
    padding: 20px;
    background: rgba(27, 17, 11, 0.54);
}

.section-mr0eq8l2 .ab-hero__metric strong {
    display: block;
    color: #ffe5bf;
    font-family: Didot, Georgia, serif;
    font-size: 32px;
    font-weight: 500;
}

.section-mr0eq8l2 .ab-hero__metric span {
    display: block;
    margin-top: 5px;
    color: rgba(255, 248, 235, 0.7);
    font-size: 13px;
}

@keyframes section-mr0eq8l2-abHeroDrift {
    from { transform: scale(1.03) translate3d(0, 0, 0); }
    to { transform: scale(1.08) translate3d(-18px, 10px, 0); }
}

@media (max-width: 767px) {
    .section-mr0eq8l2 {
        min-height: auto;
    }

    .section-mr0eq8l2 .ab-hero__veil {
        background: linear-gradient(180deg, rgba(22, 14, 9, 0.9), rgba(22, 14, 9, 0.62));
    }

    .section-mr0eq8l2 .ab-hero__content {
        padding: 74px 0 48px;
    }

    .section-mr0eq8l2 .ab-hero__title {
        font-size: 43px;
        line-height: 1.03;
    }

    .section-mr0eq8l2 .ab-hero__lead {
        font-size: 16px;
    }

    .section-mr0eq8l2 .ab-hero__actions {
        display: block;
    }

    .section-mr0eq8l2 .ab-hero__button {
        width: 100%;
        margin-bottom: 12px;
    }

    .section-mr0eq8l2 .ab-hero__metrics {
        grid-template-columns: 1fr;
        margin-top: 34px;
    }
}
</style>
{% endheader %}

<section class="section-mr0eq8l2">
    {% if this.Model.background_image %}
    <div class="ab-hero__image">
        <img property="true" data-property="background_image" method="attr" para="src" src="{% url this.Model.background_image %}" alt="{{this.Model.background_alt}}">
    </div>
    {% endif %}
    <div class="ab-hero__veil"></div>
    <div class="container">
        <div class="row">
            <div class="col-md-8 col-sm-10">
                <div class="ab-hero__content">
                    {% if this.Model.eyebrow %}<div property="true" data-property="eyebrow" method="text" class="ab-hero__eyebrow">{{this.Model.eyebrow}}</div>{% endif %}
                    {% if this.Model.title %}<h1 property="true" data-property="title" method="text" class="ab-hero__title">{{this.Model.title}}</h1>{% endif %}
                    {% if this.Model.lead %}<p property="true" data-property="lead" method="text" class="ab-hero__lead">{{this.Model.lead}}</p>{% endif %}
                    <div class="ab-hero__actions">
                        {% if this.Model.primary_label %}<a property="true" data-property="primary_link" method="attr" para="href" class="ab-hero__button ab-hero__button--solid" href="{% url this.Model.primary_link %}">{{this.Model.primary_label}}</a>{% endif %}
                        {% if this.Model.secondary_label %}<a property="true" data-property="secondary_link" method="attr" para="href" class="ab-hero__button ab-hero__button--line" href="{% url this.Model.secondary_link %}">{{this.Model.secondary_label}}</a>{% endif %}
                    </div>
                    {% if this.Model.metrics and this.Model.metrics.size > 0 %}
                    <div class="ab-hero__metrics">
                        {% for item in this.Model.metrics %}
                        <div class="ab-hero__metric">
                            <strong property="true" data-property="metrics[{{forloop.index0}}].value" method="text">{{item.value}}</strong>
                            <span property="true" data-property="metrics[{{forloop.index0}}].label" method="text">{{item.label}}</span>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
