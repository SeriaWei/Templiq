<!-- 产品系列 -->
{% header %}
<style>
.section-mpfed0mh {
  --neon-cyan: #00f5ff;
  --neon-purple: #bf00ff;
  --darker-bg: #050508;
  --card-bg: rgba(20, 20, 30, 0.8);
  --text-main: #e0e0e0;
  --text-muted: #888899;
  background: var(--darker-bg);
  padding: 100px 0;
  font-family: 'Courier New', monospace;
}

.section-mpfed0mh::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
}

.section-mpfed0mh .ssd-products__title {
  font-size: 40px;
  text-align: center;
  margin-bottom: 60px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: bold;
  color: white;
}

.section-mpfed0mh .ssd-products__subtitle {
  text-align: center;
  color: var(--text-muted);
  font-size: 18px;
  margin-bottom: 60px;
  margin-top: -30px;
}

.section-mpfed0mh .ssd-products__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
}

.section-mpfed0mh .ssd-product-card {
  background: var(--card-bg);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 40px 30px;
  position: relative;
  transition: all 0.4s ease;
  flex: 1;
  min-width: 300px;
}

.section-mpfed0mh .ssd-product-card--featured {
  border-color: var(--neon-cyan);
  transform: scale(1.05);
  box-shadow: 0 0 40px rgba(0, 245, 255, 0.3);
}

.section-mpfed0mh .ssd-product-card__ribbon {
  position: absolute;
  top: 20px;
  right: -30px;
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
  color: #0a0a0f;
  padding: 5px 30px;
  font-size: 12px;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transform: rotate(45deg);
}

.section-mpfed0mh .ssd-product-card__badge {
  display: inline-block;
  padding: 5px 15px;
  border: 1px solid var(--text-muted);
  color: var(--text-muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 20px;
}

.section-mpfed0mh .ssd-product-card--featured .ssd-product-card__badge {
  border-color: var(--neon-cyan);
  color: var(--neon-cyan);
}

.section-mpfed0mh .ssd-product-card__header {
  margin-bottom: 30px;
}

.section-mpfed0mh .ssd-product-card__name {
  font-size: 28px;
  font-weight: bold;
  margin-bottom: 10px;
}

.section-mpfed0mh .ssd-product-card__price {
  font-size: 36px;
  font-weight: bold;
  color: var(--neon-cyan);
}

.section-mpfed0mh .ssd-product-card__price-unit {
  font-size: 16px;
  color: var(--text-muted);
}

.section-mpfed0mh .ssd-product-card__specs {
  list-style: none;
  margin: 0 0 30px 0;
  padding: 0;
}

.section-mpfed0mh .ssd-product-card__specs li {
  padding: 10px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  font-size: 15px;
  color: var(--text-main);
}

.section-mpfed0mh .ssd-product-card__specs li:last-child {
  border-bottom: none;
}

.section-mpfed0mh .ssd-product-card__btn {
  width: 100%;
  padding: 15px;
  background: transparent;
  border: 2px solid var(--text-muted);
  color: var(--text-main);
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: all 0.3s ease;
}

.section-mpfed0mh .ssd-product-card__btn:hover {
  border-color: var(--neon-cyan);
  color: var(--neon-cyan);
  box-shadow: 0 0 20px rgba(0, 245, 255, 0.3);
}

.section-mpfed0mh .ssd-product-card__btn--primary {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
  border-color: transparent;
  color: #0a0a0f;
  font-weight: bold;
}

.section-mpfed0mh .ssd-product-card__btn--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0, 245, 255, 0.4);
}

.section-mpfed0mh .ssd-product-card:hover {
  transform: translateY(-10px);
  border-color: rgba(0, 245, 255, 0.5);
}

.section-mpfed0mh .ssd-product-card--featured:hover {
  transform: scale(1.05) translateY(-10px);
}

@media (max-width: 992px) {
  .section-mpfed0mh .ssd-product-card--featured {
    transform: scale(1);
  }

  .section-mpfed0mh .ssd-product-card--featured:hover {
    transform: translateY(-10px);
  }
}
</style>
{% endheader %}

<div class="section-mpfed0mh">
<div class="container">
  <div class="row">
    <div class="col-md-12 text-center">
      <h2 class="ssd-products__title" property="true" data-property="section_title" method="text">{{this.Model.section_title}}</h2>
      {% if this.Model.subtitle %}
      <p class="ssd-products__subtitle" property="true" data-property="subtitle" method="text">{{this.Model.subtitle}}</p>
      {% endif %}
    </div>
  </div>

  <div class="row ssd-products__grid">
    {% if this.Model.products and this.Model.products.size > 0 %}
    {% assign product_index = 0 %}
    {% for product in this.Model.products %}
    <div class="col-md-4 col-sm-6">
      <div class="ssd-product-card {% if product.is_featured %}ssd-product-card--featured{% endif %}">
        {% if product.badge %}
        {% if product.is_featured %}
        <div class="ssd-product-card__ribbon">{{product.badge}}</div>
        {% else %}
        <div class="ssd-product-card__badge" property="true" data-property="products[{{product_index}}].badge" method="text">{{product.badge}}</div>
        {% endif %}
        {% endif %}

        <div class="ssd-product-card__header">
          {% if product.name %}
          <h3 class="ssd-product-card__name" property="true" data-property="products[{{product_index}}].name" method="text">{{product.name}}</h3>
          {% endif %}
          {% if product.price %}
          <div class="ssd-product-card__price">
            ¥<span property="true" data-property="products[{{product_index}}].price" method="text">{{product.price}}</span>
            {% if product.price_unit %}
            <span class="ssd-product-card__price-unit" property="true" data-property="products[{{product_index}}].price_unit" method="text">{{product.price_unit}}</span>
            {% endif %}
          </div>
          {% endif %}
        </div>

        {% if product.specs and product.specs.size > 0 %}
        <ul class="ssd-product-card__specs">
          {% assign spec_index = 0 %}
          {% for spec in product.specs %}
          <li property="true" data-property="products[{{product_index}}].specs[{{spec_index}}].spec" method="text">{{spec.spec}}</li>
          {% assign spec_index = spec_index | plus: 1 %}
          {% endfor %}
        </ul>
        {% endif %}

        {% if product.btn_text %}
        <button class="ssd-product-card__btn {% if product.is_featured %}ssd-product-card__btn--primary{% endif %}">
          <span property="true" data-property="products[{{product_index}}].btn_text" method="text">{{product.btn_text}}</span>
        </button>
        {% endif %}
      </div>
    </div>
    {% assign product_index = product_index | plus: 1 %}
    {% endfor %}
    {% endif %}
  </div>
</div>
</div>