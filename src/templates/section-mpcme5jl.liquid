<!-- 页脚 -->
{% header %}
<style>

.section-mpcme5jl {
  --l-bg: #F7F3EE;
  --l-surface: #FFFFFF;
  --l-text: #1A1A2E;
  --l-text-secondary: #6B6B7B;
  --l-text-tertiary: #9A9AA8;
  --l-accent: #C44536;
  --l-border: #E3DCD2;
  --l-border-light: #EFEAE2;
  --l-font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
  --l-font-body: 'DM Sans', 'Helvetica Neue', Arial, sans-serif;

  font-family: var(--l-font-body);
  color: var(--l-text);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.section-mpcme5jl * {
  box-sizing: border-box;
}

.section-mpcme5jl img {
  max-width: 100%;
  height: auto;
  display: block;
}

.section-mpcme5jl a {
  text-decoration: none;
  transition: color 0.3s ease;
}

.section-mpcme5jl .lg-footer {
  position: relative;
  background: var(--l-bg);
  padding: 60px 0 30px;
  border-top: 1px solid var(--l-border);
}

.section-mpcme5jl .lg-footer__brand {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--l-font-display);
  font-size: 20px;
  font-weight: 600;
  color: var(--l-text);
  margin-bottom: 12px;
}

.section-mpcme5jl .lg-footer__brand span {
  color: var(--l-accent);
}

.section-mpcme5jl .lg-footer__brand-icon {
  width: 28px;
  height: 28px;
}

.section-mpcme5jl .lg-footer__brand-icon svg {
  width: 100%;
  height: 100%;
}

.section-mpcme5jl .lg-footer__desc {
  font-size: 14px;
  color: var(--l-text-secondary);
  line-height: 1.7;
  max-width: 320px;
  margin-bottom: 20px;
}

.section-mpcme5jl .lg-footer__social {
  display: flex;
  gap: 10px;
}

.section-mpcme5jl .lg-footer__social-link {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid var(--l-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--l-text-tertiary);
  transition: all 0.3s ease;
}

.section-mpcme5jl .lg-footer__social-link svg {
  width: 16px;
  height: 16px;
}

.section-mpcme5jl .lg-footer__social-link:hover {
  border-color: var(--l-accent);
  color: var(--l-accent);
  background: rgba(196, 69, 54, 0.06);
  text-decoration: none;
}

.section-mpcme5jl .lg-footer__col-title {
  font-family: var(--l-font-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--l-text);
  margin: 0 0 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--l-border-light);
}

.section-mpcme5jl .lg-footer__links {
  list-style: none;
  padding: 0;
  margin: 0;
}

.section-mpcme5jl .lg-footer__links li {
  margin-bottom: 8px;
}

.section-mpcme5jl .lg-footer__links li a {
  font-size: 14px;
  color: var(--l-text-secondary);
  text-decoration: none;
  transition: color 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.section-mpcme5jl .lg-footer__links li a:hover {
  color: var(--l-accent);
}

.section-mpcme5jl .lg-footer__links li a .lg-footer__link-arrow {
  opacity: 0;
  transition: all 0.3s ease;
  font-size: 12px;
}

.section-mpcme5jl .lg-footer__links li a:hover .lg-footer__link-arrow {
  opacity: 1;
  transform: translateX(3px);
}

.section-mpcme5jl .lg-footer__newsletter-text {
  font-size: 13px;
  color: var(--l-text-secondary);
  margin-bottom: 16px;
  line-height: 1.6;
}
}

.section-mpcme5jl .lg-footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24px;
  margin-top: 40px;
  border-top: 1px solid var(--l-border-light);
}

.section-mpcme5jl .lg-footer__copyright {
  font-size: 12px;
  color: var(--l-text-tertiary);
  margin: 0;
}

.section-mpcme5jl .lg-footer__legal {
  display: flex;
  gap: 20px;
}

.section-mpcme5jl .lg-footer__legal a {
  font-size: 12px;
  color: var(--l-text-tertiary);
  text-decoration: none;
  transition: color 0.3s ease;
}

.section-mpcme5jl .lg-footer__legal a:hover {
  color: var(--l-text);
}

@media (max-width: 767px) {
  .section-mpcme5jl .lg-footer {
    padding: 40px 0 20px;
  }

  .section-mpcme5jl .lg-footer__bottom {
    flex-direction: column;
    gap: 12px;
    text-align: center;
  }

  .section-mpcme5jl .lg-footer__col-title {
    margin-top: 24px;
  }
}
</style>
{% endheader %}

<section class="section-mpcme5jl">
  <footer class="lg-footer">
    <div class="container">
      <div class="row">
        <div class="col-xs-12 col-sm-6 col-md-3">
          <div class="lg-footer__brand">
            <span class="lg-footer__brand-icon">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <path d="M10 16c0 0 2-4 6-4s6 4 6 4-2 4-6 4-6-4-6-4z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <path d="M8 16h16" stroke="currentColor" stroke-width="1.2" opacity="0.5"/>
                <circle cx="16" cy="16" r="3" fill="currentColor" opacity="0.15"/>
              </svg>
            </span>
            <span property="true" data-property="brand_text" method="text">{{this.Model.brand_text}}<span property="true" data-property="brand_accent" method="text">{{this.Model.brand_accent}}</span></span>
          </div>
          {% if this.Model.brand_desc %}
          <p class="lg-footer__desc" property="true" data-property="brand_desc" method="text">{{this.Model.brand_desc}}</p>
          {% endif %}
          <div class="lg-footer__social">
            <a href="#" class="lg-footer__social-link" aria-label="Twitter">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
            </a>
            <a href="#" class="lg-footer__social-link" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="#" class="lg-footer__social-link" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 12a29 29 0 00.46 5.58a2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98" fill="var(--l-bg)"/></svg>
            </a>
          </div>
        </div>
        <div class="col-xs-6 col-sm-3 col-md-2 col-md-offset-1">
          {% if this.Model.column_1_title %}
          <h4 class="lg-footer__col-title" property="true" data-property="column_1_title" method="text">{{this.Model.column_1_title}}</h4>
          {% endif %}
          {% if this.Model.column_1_links.size > 0 %}
          <ul class="lg-footer__links">
            {% for link in this.Model.column_1_links %}
            <li>
              <a href="{% url link.url %}" property="true" data-property="column_1_links[{{forloop.index0}}].text" method="text">{{link.text}} <span class="lg-footer__link-arrow">→</span></a>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
        <div class="col-xs-6 col-sm-3 col-md-2">
          {% if this.Model.column_2_title %}
          <h4 class="lg-footer__col-title" property="true" data-property="column_2_title" method="text">{{this.Model.column_2_title}}</h4>
          {% endif %}
          {% if this.Model.column_2_links.size > 0 %}
          <ul class="lg-footer__links">
            {% for link in this.Model.column_2_links %}
            <li>
              <a href="{% url link.url %}" property="true" data-property="column_2_links[{{forloop.index0}}].text" method="text">{{link.text}} <span class="lg-footer__link-arrow">→</span></a>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
        <div class="col-xs-12 col-sm-6 col-md-3 col-md-offset-1">
          <h4 class="lg-footer__col-title">Stay in Touch</h4>
          {% if this.Model.newsletter_text %}
          <p class="lg-footer__newsletter-text" property="true" data-property="newsletter_text" method="text">{{this.Model.newsletter_text}}</p>
          {% endif %}
        </div>
      </div>
      <div class="row">
        <div class="col-xs-12">
          <div class="lg-footer__bottom">
            {% if this.Model.copyright %}
            <p class="lg-footer__copyright" property="true" data-property="copyright" method="text">{{this.Model.copyright}}</p>
            {% endif %}
            {% if this.Model.legal_links.size > 0 %}
            <div class="lg-footer__legal">
              {% for link in this.Model.legal_links %}
              <a href="{% url link.url %}" property="true" data-property="legal_links[{{forloop.index0}}].text" method="text">{{link.text}}</a>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </footer>
</section>

{% footer %}
{% endfooter %}
