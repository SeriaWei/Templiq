<!-- 研磨套装 -->
{% header %}
<style>
.section-mr0oyh8a {
    padding: 96px 0 112px;
    background: #efe2cc;
    color: #241a13;
    font-family: Cambria, Georgia, serif;
}
.section-mr0oyh8a .vm-lineup__intro {
    display: flex;
    align-items: end;
    margin-bottom: 42px;
}
.section-mr0oyh8a .vm-lineup__kicker,
.section-mr0oyh8a .vm-lineup__text,
.section-mr0oyh8a .vm-lineup__detail span,
.section-mr0oyh8a .vm-lineup__detail p,
.section-mr0oyh8a .vm-lineup__detail strong {
    font-family: "Trebuchet MS", Verdana, sans-serif;
}
.section-mr0oyh8a .vm-lineup__kicker {
    margin: 0 0 14px;
    color: #a55229;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
}
.section-mr0oyh8a .vm-lineup__title {
    margin: 0;
    font-size: 46px;
    line-height: 1.08;
    letter-spacing: 0;
}
.section-mr0oyh8a .vm-lineup__text {
    margin: 0;
    color: #65513f;
    font-size: 16px;
    line-height: 1.8;
}
.section-mr0oyh8a .vm-lineup__item {
    display: grid;
    grid-template-columns: 45% 55%;
    min-height: 360px;
    background: #fff6e7;
    border: 1px solid rgba(36, 26, 19, 0.12);
}
.section-mr0oyh8a .vm-lineup__item--dark {
    background: #221913;
    color: #fff1d7;
}
.section-mr0oyh8a .vm-lineup__image img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 360px;
    object-fit: cover;
}
.section-mr0oyh8a .vm-lineup__detail {
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.section-mr0oyh8a .vm-lineup__detail span {
    color: #b35e2f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
}
.section-mr0oyh8a .vm-lineup__item--dark .vm-lineup__detail span,
.section-mr0oyh8a .vm-lineup__item--dark .vm-lineup__detail strong {
    color: #f0b35f;
}
.section-mr0oyh8a .vm-lineup__detail h3 {
    margin: 18px 0 16px;
    font-size: 32px;
    line-height: 1.1;
}
.section-mr0oyh8a .vm-lineup__detail p {
    margin: 0 0 24px;
    color: #665345;
    font-size: 15px;
    line-height: 1.75;
}
.section-mr0oyh8a .vm-lineup__item--dark .vm-lineup__detail p {
    color: rgba(255, 241, 215, 0.72);
}
.section-mr0oyh8a .vm-lineup__detail strong {
    color: #8f4624;
    font-size: 28px;
}
@media (max-width: 991px) {
    .section-mr0oyh8a .vm-lineup__intro { display: block; }
    .section-mr0oyh8a .vm-lineup__text { margin-top: 22px; }
    .section-mr0oyh8a .vm-lineup__item { grid-template-columns: 1fr; margin-bottom: 20px; }
}
@media (max-width: 767px) {
    .section-mr0oyh8a { padding: 64px 0; }
    .section-mr0oyh8a .vm-lineup__title { font-size: 34px; }
}
</style>
{% endheader %}

<section class="section-mr0oyh8a" id="{{this.Model.anchor_id}}">
    <div class="container">
        <div class="row vm-lineup__intro">
            <div class="col-md-6">
                {% if this.Model.kicker %}<p class="vm-lineup__kicker" property="true" data-property="kicker" method="text">{{this.Model.kicker}}</p>{% endif %}
                {% if this.Model.title %}<h2 class="vm-lineup__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>{% endif %}
            </div>
            <div class="col-md-5 col-md-offset-1">
                {% if this.Model.text %}<p class="vm-lineup__text" property="true" data-property="text" method="text">{{this.Model.text}}</p>{% endif %}
            </div>
        </div>
        <div class="row vm-lineup__cards">
            {% for product in this.Model.products %}
            <div class="col-md-6 col-sm-6">
                <article class="vm-lineup__item{% if product.is_dark %} vm-lineup__item--dark{% endif %}">
                    <div class="vm-lineup__image">
                        {% if product.image_src %}<img property="true" data-property="products[{{forloop.index0}}].image_src" method="attr" para="src" src="{% url product.image_src %}" alt="{{product.image_alt}}">{% endif %}
                    </div>
                    <div class="vm-lineup__detail">
                        {% if product.badge %}<span property="true" data-property="products[{{forloop.index0}}].badge" method="text">{{product.badge}}</span>{% endif %}
                        {% if product.name %}<h3 property="true" data-property="products[{{forloop.index0}}].name" method="text">{{product.name}}</h3>{% endif %}
                        {% if product.description %}<p property="true" data-property="products[{{forloop.index0}}].description" method="text">{{product.description}}</p>{% endif %}
                        {% if product.price %}<strong property="true" data-property="products[{{forloop.index0}}].price" method="text">{{product.price}}</strong>{% endif %}
                    </div>
                </article>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
