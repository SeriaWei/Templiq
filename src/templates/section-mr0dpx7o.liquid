<!-- 春茶首屏 -->
{% header %}
<style>
.section-mr0dpx7o {
    --tea-ink: #172416;
    --tea-ink-soft: #4d6047;
    --tea-leaf: #526f2d;
    --tea-leaf-dark: #294315;
    --tea-lime: #d8e86e;
    --tea-paper: #f8f3df;
    --tea-rice: #fffaf0;
    --tea-line: rgba(23, 36, 22, .16);
    color: var(--tea-ink);
    background: linear-gradient(90deg, rgba(23,36,22,.06) 1px, transparent 1px), linear-gradient(0deg, rgba(23,36,22,.05) 1px, transparent 1px), var(--tea-paper);
    background-size: 72px 72px;
    font-family: "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    font-size: 16px;
    line-height: 1.65;
    overflow: hidden;
}

.section-mr0dpx7o .gt-hero {
    position: relative;
    min-height: 96vh;
    padding: 80px 0 60px;
}

.section-mr0dpx7o .gt-hero__paper {
    position: absolute;
    top: -180px;
    right: -100px;
    width: 580px;
    height: 580px;
    border: 1px solid rgba(41,67,21,.18);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(216,232,110,.48) 0 18%, transparent 19%), repeating-conic-gradient(from -20deg, rgba(82,111,45,.12) 0 7deg, transparent 7deg 16deg);
    opacity: .72;
}

.section-mr0dpx7o .gt-hero__row {
    display: flex;
    align-items: center;
    min-height: calc(96vh - 140px);
}

.section-mr0dpx7o .gt-hero__copy {
    max-width: 680px;
    padding: 40px 0;
}

.section-mr0dpx7o .gt-kicker {
    margin: 0 0 14px;
    color: var(--tea-leaf-dark);
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
}

.section-mr0dpx7o .gt-hero__title {
    margin: 0;
    font-size: clamp(72px, 14vw, 156px);
    line-height: .86;
    font-weight: 500;
    letter-spacing: 0;
}

.section-mr0dpx7o .gt-hero__lead {
    max-width: 540px;
    margin: 30px 0 0;
    color: var(--tea-ink-soft);
    font-size: 22px;
    line-height: 1.55;
}

.section-mr0dpx7o .gt-hero__actions {
    display: flex;
    gap: 14px;
    margin-top: 34px;
    flex-wrap: wrap;
}

.section-mr0dpx7o .gt-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border: 1px solid var(--tea-ink);
    border-radius: 0;
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform .25s ease, background .25s ease, color .25s ease, box-shadow .25s ease;
}

.section-mr0dpx7o .gt-button:hover,
.section-mr0dpx7o .gt-button:focus {
    text-decoration: none;
    transform: translateY(-2px);
}

.section-mr0dpx7o .gt-button--solid {
    color: var(--tea-rice);
    background: var(--tea-ink);
    box-shadow: 8px 8px 0 var(--tea-lime);
}

.section-mr0dpx7o .gt-button--solid:hover,
.section-mr0dpx7o .gt-button--solid:focus {
    color: var(--tea-rice);
    box-shadow: 4px 4px 0 var(--tea-lime);
}

.section-mr0dpx7o .gt-button--line {
    color: var(--tea-ink);
    background: rgba(255,250,240,.52);
}

.section-mr0dpx7o .gt-button--line:hover,
.section-mr0dpx7o .gt-button--line:focus {
    color: var(--tea-rice);
    background: var(--tea-leaf-dark);
}

.section-mr0dpx7o .gt-hero__metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    max-width: 560px;
    margin-top: 50px;
    border: 1px solid var(--tea-line);
    background: var(--tea-line);
}

.section-mr0dpx7o .gt-hero__metrics div {
    min-height: 100px;
    padding: 18px;
    background: rgba(255,250,240,.72);
}

.section-mr0dpx7o .gt-hero__metrics strong,
.section-mr0dpx7o .gt-hero__metrics span {
    display: block;
}

.section-mr0dpx7o .gt-hero__metrics strong {
    font-family: Georgia, serif;
    font-size: 30px;
    line-height: 1;
}

.section-mr0dpx7o .gt-hero__metrics span {
    margin-top: 8px;
    color: var(--tea-ink-soft);
    font-size: 13px;
}

.section-mr0dpx7o .gt-hero__stage {
    position: relative;
    min-height: 620px;
}

.section-mr0dpx7o .gt-hero__image {
    position: absolute;
    top: 30px;
    right: 0;
    width: 82%;
    height: 540px;
    object-fit: cover;
    border-radius: 50% 50% 40px 40px;
    filter: saturate(.88) contrast(1.05);
    box-shadow: 0 32px 70px rgba(23,36,22,.24);
}

.section-mr0dpx7o .gt-hero__tin {
    position: absolute;
    left: 10px;
    bottom: 20px;
    width: 220px;
    height: 340px;
    transform: rotate(-5deg);
}

.section-mr0dpx7o .gt-hero__tin-lid,
.section-mr0dpx7o .gt-hero__tin-body {
    position: absolute;
    left: 0;
    width: 100%;
    border: 1px solid rgba(23,36,22,.32);
    background: linear-gradient(120deg, #f7ffe4, #a7ba5f 42%, #263c19 43%, #5d7d34 82%);
    box-shadow: 16px 14px 0 rgba(216,232,110,.55);
}

.section-mr0dpx7o .gt-hero__tin-lid {
    top: 0;
    height: 48px;
    border-radius: 50% / 44%;
}

.section-mr0dpx7o .gt-hero__tin-body {
    top: 24px;
    height: 300px;
    border-radius: 18px 18px 28px 28px;
}

.section-mr0dpx7o .gt-hero__tin-label {
    position: absolute;
    top: 110px;
    left: 50%;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(-50%);
    border: 1px solid rgba(255,250,240,.7);
    color: var(--tea-rice);
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: .12em;
    text-align: center;
}

.section-mr0dpx7o .gt-hero__note {
    position: absolute;
    z-index: 2;
    padding: 10px 13px;
    border: 1px solid var(--tea-ink);
    background: var(--tea-rice);
    color: var(--tea-ink);
    font-size: 13px;
    box-shadow: 6px 6px 0 rgba(23,36,22,.14);
}

.section-mr0dpx7o .gt-hero__note--top {
    top: 70px;
    left: -20px;
}

.section-mr0dpx7o .gt-hero__note--bottom {
    right: 10px;
    bottom: 80px;
}

.section-mr0dpx7o .gt-reveal {
    opacity: 0;
    transform: translateY(22px);
    animation: section-mr0dpx7o-rise .75s cubic-bezier(.2, .8, .2, 1) forwards;
}

@keyframes section-mr0dpx7o-rise {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 991px) {
    .section-mr0dpx7o .gt-hero__row {
        display: block;
    }

    .section-mr0dpx7o .gt-hero__stage {
        min-height: 540px;
    }
}

@media (max-width: 767px) {
    .section-mr0dpx7o .gt-hero {
        min-height: 0;
        padding: 50px 0 30px;
    }

    .section-mr0dpx7o .gt-hero__lead {
        font-size: 18px;
    }

    .section-mr0dpx7o .gt-hero__actions {
        display: grid;
    }

    .section-mr0dpx7o .gt-button {
        width: 100%;
    }

    .section-mr0dpx7o .gt-hero__metrics {
        grid-template-columns: 1fr;
    }

    .section-mr0dpx7o .gt-hero__stage {
        min-height: 430px;
    }

    .section-mr0dpx7o .gt-hero__image {
        width: 88%;
        height: 340px;
    }

    .section-mr0dpx7o .gt-hero__tin {
        width: 150px;
        height: 250px;
    }

    .section-mr0dpx7o .gt-hero__tin-body {
        height: 220px;
    }

    .section-mr0dpx7o .gt-hero__tin-label {
        top: 80px;
        width: 88px;
        height: 88px;
        font-size: 17px;
    }
}
</style>
{% endheader %}

<div class="section-mr0dpx7o">
    <section class="gt-hero" aria-labelledby="heroTitle-mr0dpx7o">
        <div class="gt-hero__paper" aria-hidden="true"></div>
        <div class="container">
            <div class="row gt-hero__row">
                <div class="col-md-7 col-sm-12">
                    <div class="gt-hero__copy gt-reveal">
                        {% if this.Model.kicker %}<p class="gt-kicker" property="true" data-property="kicker" method="text">{{this.Model.kicker}}</p>{% endif %}
                        {% if this.Model.title %}<h1 id="heroTitle-mr0dpx7o" class="gt-hero__title" property="true" data-property="title" method="text">{{this.Model.title}}</h1>{% endif %}
                        {% if this.Model.lead %}<p class="gt-hero__lead" property="true" data-property="lead" method="text">{{this.Model.lead}}</p>{% endif %}
                        <div class="gt-hero__actions" role="group" aria-label="产品操作">
                            {% if this.Model.primary_link_text %}<a class="gt-button gt-button--solid" property="true" data-property="primary_link_url" method="attr" para="href" href="{% url this.Model.primary_link_url %}">{{this.Model.primary_link_text}}</a>{% endif %}
                            {% if this.Model.secondary_link_text %}<a class="gt-button gt-button--line" property="true" data-property="secondary_link_url" method="attr" para="href" href="{% url this.Model.secondary_link_url %}">{{this.Model.secondary_link_text}}</a>{% endif %}
                        </div>
                        {% if this.Model.metrics %}
                        <div class="gt-hero__metrics" aria-label="核心指标">
                            {% for metric in this.Model.metrics %}
                            <div>
                                {% if metric.value %}<strong property="true" data-property="metrics[{{forloop.index0}}].value" method="text">{{metric.value}}</strong>{% endif %}
                                {% if metric.label %}<span property="true" data-property="metrics[{{forloop.index0}}].label" method="text">{{metric.label}}</span>{% endif %}
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
                <div class="col-md-5 col-sm-12">
                    <div class="gt-hero__stage gt-reveal" style="animation-delay: .14s;">
                        {% if this.Model.hero_image %}<img class="gt-hero__image" property="true" data-property="hero_image" method="attr" para="src" src="{% url this.Model.hero_image %}" alt="{{this.Model.hero_image_alt}}">{% endif %}
                        <div class="gt-hero__tin" aria-hidden="true">
                            <span class="gt-hero__tin-lid"></span>
                            <span class="gt-hero__tin-body"></span>
                            {% if this.Model.tin_label %}<span class="gt-hero__tin-label" property="true" data-property="tin_label" method="html">{{this.Model.tin_label | raw}}</span>{% endif %}
                        </div>
                        {% if this.Model.top_note %}<div class="gt-hero__note gt-hero__note--top" property="true" data-property="top_note" method="text">{{this.Model.top_note}}</div>{% endif %}
                        {% if this.Model.bottom_note %}<div class="gt-hero__note gt-hero__note--bottom" property="true" data-property="bottom_note" method="text">{{this.Model.bottom_note}}</div>{% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
