<!-- 数据统计 -->
{% header %}
<style>
.section-mpfed1tc {
  --neon-cyan: #00f5ff;
  --dark-bg: #0a0a0f;
  --darker-bg: #050508;
  --text-muted: #888899;
  background: linear-gradient(135deg, var(--dark-bg), var(--darker-bg));
  padding: 80px 0;
  font-family: 'Courier New', monospace;
  position: relative;
}

.section-mpfed1tc::before,
.section-mpfed1tc::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
}

.section-mpfed1tc::before {
  top: 0;
}

.section-mpfed1tc::after {
  bottom: 0;
}

.section-mpfed1tc .ssd-stat-item {
  text-align: center;
  padding: 30px 20px;
}

.section-mpfed1tc .ssd-stat-item__value {
  font-size: 50px;
  font-weight: bold;
  color: var(--neon-cyan);
  text-shadow: 0 0 30px var(--neon-cyan);
  line-height: 1;
  margin-bottom: 10px;
  font-family: 'Courier New', monospace;
}

.section-mpfed1tc .ssd-stat-item__label {
  font-size: 16px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

@media (max-width: 768px) {
  .section-mpfed1tc .ssd-stat-item__value {
    font-size: 36px;
  }
}
</style>
{% endheader %}

<div class="section-mpfed1tc">
<div class="container">
  <div class="row">
    {% if this.Model.stats and this.Model.stats.size > 0 %}
    {% assign stat_index = 0 %}
    {% for stat in this.Model.stats %}
    <div class="col-md-3 col-sm-6 ssd-stat-item">
      <div class="ssd-stat-item__value"
           data-target="{{stat.value}}"
           data-is-decimal="{{stat.is_decimal | default: false}}"
           property="true"
           data-property="stats[{{stat_index}}].value"
           method="text">{{stat.value}}</div>
      <div class="ssd-stat-item__label" property="true" data-property="stats[{{stat_index}}].label" method="text">{{stat.label}}</div>
    </div>
    {% assign stat_index = stat_index | plus: 1 %}
    {% endfor %}
    {% endif %}
  </div>
</div>
</div>

{% footer %}
<script type="text/javascript">
(function() {
  var section = document.querySelector('.section-mpfed1tc');
  if (!section) return;

  var statValues = section.querySelectorAll('.ssd-stat-item__value');

  var observerOptions = {
    threshold: 0.5
  };

  var statsObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        var target = parseFloat(el.dataset.target);
        var isDecimal = el.dataset.isDecimal === 'true';
        var duration = 2000;

        animateValue(el, 0, target, duration, isDecimal);
        statsObserver.unobserve(el);
      }
    });
  }, observerOptions);

  statValues.forEach(function(el) {
    statsObserver.observe(el);
  });

  function animateValue(element, start, end, duration, isDecimal) {
    var startTime = performance.now();

    function update(currentTime) {
      var elapsed = currentTime - startTime;
      var progress = Math.min(elapsed / duration, 1);
      var easeProgress = 1 - Math.pow(1 - progress, 4);
      var currentValue = start + (end - start) * easeProgress;

      if (isDecimal) {
        element.textContent = currentValue.toFixed(1);
      } else if (end >= 1000000) {
        element.textContent = Math.floor(currentValue / 1000000) + 'M+';
      } else if (end >= 1000) {
        element.textContent = Math.floor(currentValue).toLocaleString();
      } else {
        element.textContent = Math.floor(currentValue);
      }

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }

    requestAnimationFrame(update);
  }
})();
</script>
{% endfooter %}