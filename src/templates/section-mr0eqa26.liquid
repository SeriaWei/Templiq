<!-- 精准萃取 -->
{% header %}
<style>
.section-mr0eqa26 {
    position: relative;
    padding: 86px 0 98px;
    overflow: hidden;
    color: #231b16;
    background: linear-gradient(135deg, rgba(199, 112, 49, 0.08) 0 25%, transparent 25% 50%, rgba(22, 71, 67, 0.08) 50% 75%, transparent 75%), #f5efe4;
    background-size: 34px 34px, auto;
    font-family: "Avenir Next", "Gill Sans", "Microsoft YaHei", sans-serif;
}

.section-mr0eqa26 .ab-precision__intro {
    display: flex;
    align-items: flex-end;
    margin-bottom: 42px;
}

.section-mr0eqa26 .ab-precision__kicker {
    margin: 0 0 14px;
    color: #997042;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
}

.section-mr0eqa26 .ab-precision__title {
    margin: 0;
    color: #231b16;
    font-family: Didot, "Bodoni 72", Georgia, "STSong", serif;
    font-size: 48px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: 0;
}

.section-mr0eqa26 .ab-precision__copy {
    margin: 0;
    color: #6f5a49;
    font-size: 17px;
    line-height: 1.85;
}

.section-mr0eqa26 .ab-precision__grid {
    display: flex;
    align-items: stretch;
}

.section-mr0eqa26 .ab-precision__card {
    min-height: 365px;
    height: 100%;
    padding: 34px;
    border: 1px solid rgba(65, 42, 28, 0.18);
    background: rgba(255, 252, 244, 0.82);
    box-shadow: 0 26px 70px rgba(60, 34, 18, 0.08);
}

.section-mr0eqa26 .ab-precision__card--image {
    padding: 0;
    overflow: hidden;
    background: #24150e;
}

.section-mr0eqa26 .ab-precision__card--image img {
    display: block;
    width: 100%;
    height: 365px;
    object-fit: cover;
    filter: saturate(0.86) contrast(1.08);
    transition: transform 0.6s ease;
}

.section-mr0eqa26 .ab-precision__card--image:hover img {
    transform: scale(1.05);
}

.section-mr0eqa26 .ab-precision__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    margin-bottom: 84px;
    border: 1px solid rgba(35, 27, 22, 0.22);
    border-radius: 50%;
    color: #b46c31;
    font-family: Didot, Georgia, serif;
    font-size: 22px;
}

.section-mr0eqa26 .ab-precision__card h3 {
    margin: 0 0 14px;
    color: #24150e;
    font-size: 24px;
    font-weight: 800;
}

.section-mr0eqa26 .ab-precision__card p {
    margin: 0;
    color: #705746;
    font-size: 15px;
    line-height: 1.75;
}

@media (max-width: 767px) {
    .section-mr0eqa26 {
        padding: 58px 0 64px;
    }

    .section-mr0eqa26 .ab-precision__intro,
    .section-mr0eqa26 .ab-precision__grid {
        display: block;
    }

    .section-mr0eqa26 .ab-precision__title {
        margin-bottom: 20px;
        font-size: 36px;
    }

    .section-mr0eqa26 .ab-precision__card {
        min-height: 0;
        margin-bottom: 16px;
    }

    .section-mr0eqa26 .ab-precision__icon {
        margin-bottom: 52px;
    }
}
</style>
{% endheader %}

<section class="section-mr0eqa26" id="precision">
    <div class="container">
        <div class="row ab-precision__intro">
            <div class="col-md-5 col-sm-6">
                {% if this.Model.kicker %}<p property="true" data-property="kicker" method="text" class="ab-precision__kicker">{{this.Model.kicker}}</p>{% endif %}
                {% if this.Model.title %}<h2 property="true" data-property="title" method="text" class="ab-precision__title">{{this.Model.title}}</h2>{% endif %}
            </div>
            <div class="col-md-6 col-md-offset-1 col-sm-6">
                {% if this.Model.copy %}<p property="true" data-property="copy" method="text" class="ab-precision__copy">{{this.Model.copy}}</p>{% endif %}
            </div>
        </div>

        <div class="row ab-precision__grid">
            {% for item in this.Model.feature_cards %}
            {% if item.image != "" %}
            <div class="col-md-4 col-sm-4">
                <article class="ab-precision__card ab-precision__card--image">
                    <img property="true" data-property="feature_cards[{{forloop.index0}}].image" method="attr" para="src" src="{% url item.image %}" alt="{{item.image_alt}}">
                </article>
            </div>
            {% else %}
            <div class="col-md-4 col-sm-4">
                <article class="ab-precision__card">
                    {% if item.number != "" %}<span property="true" data-property="feature_cards[{{forloop.index0}}].number" method="text" class="ab-precision__icon">{{item.number}}</span>{% endif %}
                    {% if item.title != "" %}<h3 property="true" data-property="feature_cards[{{forloop.index0}}].title" method="text">{{item.title}}</h3>{% endif %}
                    {% if item.description != "" %}<p property="true" data-property="feature_cards[{{forloop.index0}}].description" method="text">{{item.description}}</p>{% endif %}
                </article>
            </div>
            {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
