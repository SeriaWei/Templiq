<!-- 行动号召 -->
{% header %}
<style>
.section-mp9t43xz {
  --sr-bg: #0e0b08;
  --sr-surface: #1a1612;
  --sr-surface-raised: #24201a;
  --sr-border: #332e27;
  --sr-text: #e8e2d8;
  --sr-text-secondary: #9c9488;
  --sr-accent-gold: #c9a84e;
  --sr-accent-gold-soft: rgba(201, 168, 78, 0.12);
  --sr-accent-ruby: #8b2f3f;
  --sr-font-heading: Georgia, "Times New Roman", Times, serif;
  --sr-font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --sr-font-mono: "SF Mono", "Fira Code", Consolas, monospace;
  font-size: 10px;
}
.section-mp9t43xz .sr-cta {
  position: relative;
  padding: 100px 0;
  background: var(--sr-bg);
  overflow: hidden;
}
.section-mp9t43xz .sr-cta__bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}
.section-mp9t43xz .sr-cta__pattern {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 800px 400px at 50% 30%, rgba(201, 168, 78, 0.03) 0%, transparent 60%),
    radial-gradient(ellipse 400px 600px at 80% 70%, rgba(139, 47, 63, 0.02) 0%, transparent 50%);
}
.section-mp9t43xz .sr-cta__title {
  font-family: var(--sr-font-heading);
  font-size: 56px;
  font-weight: 700;
  line-height: 1.1;
  color: var(--sr-text);
  margin: 0 0 20px;
  letter-spacing: -0.02em;
}
.section-mp9t43xz .sr-cta__text {
  font-size: 18px;
  line-height: 1.7;
  color: var(--sr-text-secondary);
  max-width: 560px;
  margin: 0 auto 36px;
}
.section-mp9t43xz .sr-cta__actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.section-mp9t43xz .sr-cta__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 600;
  padding: 14px 32px;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}
.section-mp9t43xz .sr-cta__btn--primary {
  color: var(--sr-bg);
  background: var(--sr-accent-gold);
}
.section-mp9t43xz .sr-cta__btn--primary:hover {
  background: #dbb956;
  color: var(--sr-bg);
  text-decoration: none;
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(201, 168, 78, 0.4);
}
.section-mp9t43xz .sr-cta__btn--outline {
  color: var(--sr-text);
  border: 1px solid var(--sr-border);
}
.section-mp9t43xz .sr-cta__btn--outline:hover {
  border-color: var(--sr-accent-gold);
  color: var(--sr-accent-gold);
  text-decoration: none;
  transform: translateY(-2px);
}
.section-mp9t43xz .sr-cta__footnote {
  font-size: 12px;
  color: var(--sr-text-secondary);
  opacity: 0.6;
  margin: 0;
  letter-spacing: 0.03em;
}
@media (max-width: 768px) {
  .section-mp9t43xz .sr-cta { padding: 60px 0; }
  .section-mp9t43xz .sr-cta__title { font-size: 36px; }
  .section-mp9t43xz .sr-cta__text { font-size: 16px; padding: 0 16px; }
  .section-mp9t43xz .sr-cta__actions { flex-direction: column; padding: 0 16px; }
  .section-mp9t43xz .sr-cta__btn { width: 100%; justify-content: center; }
}
</style>
{% endheader %}

<div class="section-mp9t43xz">
<section class="sr-cta" id="cta">
  <div class="sr-cta__bg">
    <div class="sr-cta__pattern"></div>
  </div>
  <div class="container">
    <div class="row">
      <div class="col-md-8 col-md-offset-2 text-center">
        {% if this.Model.section_label %}
        <p class="sr-section-label sr-section-label--light" property="true" data-property="section_label" method="text">{{this.Model.section_label}}</p>
        {% endif %}
        <h2 class="sr-cta__title">
          <span property="true" data-property="title_prefix" method="text">{{this.Model.title_prefix}}</span>
          {% if this.Model.title_accent %} <span class="sr-text-gold" property="true" data-property="title_accent" method="text">{{this.Model.title_accent}}</span>{% endif %}
        </h2>
        {% if this.Model.description %}
        <p class="sr-cta__text" property="true" data-property="description" method="text">{{this.Model.description}}</p>
        {% endif %}
        <div class="sr-cta__actions">
          {% if this.Model.primary_btn_text %}
          <a property="true" data-property="primary_btn_href" method="attr" para="href" href="{% url this.Model.primary_btn_href %}" class="sr-cta__btn sr-cta__btn--primary">
            <span property="true" data-property="primary_btn_text" method="text">{{this.Model.primary_btn_text}}</span>
            {{this.Model.primary_btn_svg | raw}}
          </a>
          {% endif %}
          {% if this.Model.secondary_btn_text %}
          <a property="true" data-property="secondary_btn_href" method="attr" para="href" href="{% url this.Model.secondary_btn_href %}" class="sr-cta__btn sr-cta__btn--outline">
            <span property="true" data-property="secondary_btn_text" method="text">{{this.Model.secondary_btn_text}}</span>
          </a>
          {% endif %}
        </div>
        {% if this.Model.footnote %}
        <p class="sr-cta__footnote" property="true" data-property="footnote" method="text">{{this.Model.footnote}}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>
</div>
