<!-- 咖啡配方卡 -->
{% header %}
<style>
.section-mr0pzkoz {
    padding: 96px 0 104px;
    background: linear-gradient(135deg, rgba(184, 48, 31, 0.16) 0 1px, transparent 1px 38px), #f7efe1;
    color: #221711;
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
}
.section-mr0pzkoz .bd-library__intro {
    display: flex;
    align-items: end;
    margin-bottom: 34px;
}
.section-mr0pzkoz .bd-library__kicker {
    margin: 0 0 18px;
    color: #763421;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-mr0pzkoz .bd-library__title {
    margin: 0;
    font-family: Cambria, Georgia, serif;
    font-size: 54px;
    line-height: 1.02;
    letter-spacing: 0;
}
.section-mr0pzkoz .bd-library__copy {
    margin: 0;
    color: #5a483c;
    font-size: 17px;
    line-height: 1.8;
}
.section-mr0pzkoz .bd-library__card {
    min-height: 310px;
    padding: 30px;
    border: 1px solid rgba(34, 23, 17, 0.18);
    background: rgba(255, 247, 232, 0.72);
    box-shadow: 12px 12px 0 rgba(36, 67, 61, 0.1);
}
.section-mr0pzkoz .bd-library__card--accent {
    background: #b8301f;
    color: #fff7e8;
    transform: translateY(22px);
}
.section-mr0pzkoz .bd-library__card small {
    display: block;
    color: #763421;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-mr0pzkoz .bd-library__card--accent small {
    color: #f4c98b;
}
.section-mr0pzkoz .bd-library__card h3 {
    margin: 92px 0 16px;
    font-family: Didot, "Bodoni 72", Georgia, serif;
    font-size: 34px;
    letter-spacing: 0;
}
.section-mr0pzkoz .bd-library__card p {
    margin: 0;
    color: #5a483c;
    font-size: 16px;
    line-height: 1.7;
}
.section-mr0pzkoz .bd-library__card--accent p {
    color: rgba(255, 247, 232, 0.78);
}
@media (max-width: 767px) {
    .section-mr0pzkoz {
        padding: 66px 0;
    }
    .section-mr0pzkoz .bd-library__intro {
        display: block;
    }
    .section-mr0pzkoz .bd-library__title {
        font-size: 40px;
        margin-bottom: 18px;
    }
    .section-mr0pzkoz .bd-library__card,
    .section-mr0pzkoz .bd-library__card--accent {
        min-height: 0;
        margin-bottom: 18px;
        transform: none;
    }
    .section-mr0pzkoz .bd-library__card h3 {
        margin-top: 48px;
    }
}
</style>
{% endheader %}

<section class="section-mr0pzkoz">
    <div class="container">
        <div class="row bd-library__intro">
            <div class="col-md-7">
                {% if this.Model.eyebrow %}<p class="bd-library__kicker" property="true" data-property="eyebrow" method="text">{{this.Model.eyebrow}}</p>{% endif %}
                {% if this.Model.title %}<h2 class="bd-library__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>{% endif %}
            </div>
            <div class="col-md-5">
                {% if this.Model.copy %}<p class="bd-library__copy" property="true" data-property="copy" method="text">{{this.Model.copy}}</p>{% endif %}
            </div>
        </div>
        {% if this.Model.cards.size > 0 %}
        <div class="row bd-library__cards">
            {% for item in this.Model.cards %}
            <div class="col-sm-4">
                <article class="bd-library__card{% if item.is_accent %} bd-library__card--accent{% endif %}">
                    {% if item.origin %}<small property="true" data-property="cards[{{forloop.index0}}].origin" method="text">{{item.origin}}</small>{% endif %}
                    {% if item.title %}<h3 property="true" data-property="cards[{{forloop.index0}}].title" method="text">{{item.title}}</h3>{% endif %}
                    {% if item.copy %}<p property="true" data-property="cards[{{forloop.index0}}].copy" method="text">{{item.copy}}</p>{% endif %}
                </article>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
