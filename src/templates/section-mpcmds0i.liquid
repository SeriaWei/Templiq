<!-- 主视觉 -->
{% header %}
<style>

.section-mpcmds0i {
  /* Colors */
  --l-bg: #F7F3EE;
  --l-bg-alt: #EFE8DE;
  --l-bg-dark: #1B2838;
  --l-surface: #FFFFFF;
  --l-surface-alt: #FDFBF9;
  --l-text: #1A1A2E;
  --l-text-secondary: #6B6B7B;
  --l-text-tertiary: #9A9AA8;
  --l-text-light: #F5F0E8;
  --l-accent: #C44536;
  --l-accent-hover: #A8372A;
  --l-accent-alt: #D4A853;
  --l-accent-glow: rgba(196, 69, 54, 0.12);
  --l-primary: #1E3A5F;
  --l-primary-light: #2A5280;
  --l-border: #E3DCD2;
  --l-border-light: #EFEAE2;
  --l-success: #3A9D6E;
  --l-font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
  --l-font-body: 'DM Sans', 'Helvetica Neue', Arial, sans-serif;
  --l-nav-height: 64px;
  --l-container-padding: 24px;
  --l-radius-sm: 6px;
  --l-radius-md: 12px;
  --l-radius-lg: 20px;
  --l-shadow-sm: 0 1px 3px rgba(26, 26, 46, 0.06);
  --l-shadow-md: 0 4px 16px rgba(26, 26, 46, 0.08);
  --l-shadow-lg: 0 12px 40px rgba(26, 26, 46, 0.1);
  --l-shadow-card: 0 2px 8px rgba(26, 26, 46, 0.04);

  font-family: var(--l-font-body);
  color: var(--l-text);
  background: var(--l-bg);
  line-height: 1.7;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

.section-mpcmds0i * {
  box-sizing: border-box;
}

.section-mpcmds0i img {
  max-width: 100%;
  height: auto;
  display: block;
}

.section-mpcmds0i a {
  color: var(--l-accent);
  text-decoration: none;
  transition: color 0.3s ease;
}

.section-mpcmds0i a:hover,
.section-mpcmds0i a:focus {
  color: var(--l-accent-hover);
  text-decoration: none;
}

@keyframes section-mpcmds0i-fade-up {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes section-mpcmds0i-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes section-mpcmds0i-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}

@keyframes section-mpcmds0i-pulse-subtle {
  0%, 100% { opacity: 0.15; }
  50% { opacity: 0.3; }
}

@keyframes section-mpcmds0i-spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ============================================================
   Hero
   ============================================================ */

.section-mpcmds0i .lg-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: var(--l-bg);
  overflow: hidden;
  padding: 120px 0 80px;
}

.section-mpcmds0i .lg-hero__bg-texture {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 80% 20%, rgba(212, 168, 83, 0.06) 0%, transparent 60%),
    radial-gradient(ellipse at 20% 80%, rgba(196, 69, 54, 0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(30, 58, 95, 0.03) 0%, transparent 70%);
  pointer-events: none;
}

.section-mpcmds0i .lg-hero__globe-bg {
  position: absolute;
  right: -10%;
  top: 50%;
  transform: translateY(-50%);
  width: 70vmin;
  height: 70vmin;
  pointer-events: none;
  opacity: 0.12;
}

.section-mpcmds0i .lg-hero__globe-bg svg {
  width: 100%;
  height: 100%;
  animation: section-mpcmds0i-spin-slow 120s linear infinite;
}

.section-mpcmds0i .lg-hero__compass {
  position: absolute;
  left: 5%;
  bottom: 15%;
  width: 12vmin;
  height: 12vmin;
  opacity: 0.07;
  pointer-events: none;
}

.section-mpcmds0i .lg-hero__compass svg {
  width: 100%;
  height: 100%;
}

.section-mpcmds0i .lg-hero__latitudes {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.section-mpcmds0i .lg-hero__latitudes-line {
  position: absolute;
  left: -5%;
  right: -5%;
  height: 1px;
  background: var(--l-accent-alt);
  opacity: 0.06;
}

.section-mpcmds0i .lg-hero__latitudes-line:nth-child(1) { top: 20%; }
.section-mpcmds0i .lg-hero__latitudes-line:nth-child(2) { top: 40%; }
.section-mpcmds0i .lg-hero__latitudes-line:nth-child(3) { top: 60%; }
.section-mpcmds0i .lg-hero__latitudes-line:nth-child(4) { top: 80%; }

.section-mpcmds0i .lg-hero__content {
  position: relative;
  z-index: 2;
  width: 100%;
}

.section-mpcmds0i .lg-hero__inner {
  display: flex;
  align-items: center;
  gap: 60px;
}

.section-mpcmds0i .lg-hero__text {
  flex: 1 1 50%;
  max-width: 580px;
}

.section-mpcmds0i .lg-hero__visual {
  flex: 1 1 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.section-mpcmds0i .lg-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--l-accent);
  background: rgba(196, 69, 54, 0.08);
  padding: 6px 16px;
  border-radius: 100px;
  margin-bottom: 24px;
  border: 1px solid rgba(196, 69, 54, 0.15);
}

.section-mpcmds0i .lg-hero__badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--l-accent);
  animation: section-mpcmds0i-pulse-subtle 2s ease-in-out infinite;
}

.section-mpcmds0i .lg-hero__title {
  font-family: var(--l-font-display);
  font-size: 64px;
  font-weight: 700;
  line-height: 1.08;
  color: var(--l-text);
  margin: 0 0 16px;
  letter-spacing: -0.02em;
}

.section-mpcmds0i .lg-hero__title-line {
  display: block;
}

.section-mpcmds0i .lg-hero__title-line--accent {
  color: var(--l-accent);
  font-style: italic;
  font-weight: 600;
}

.section-mpcmds0i .lg-hero__subtitle {
  font-size: 18px;
  color: var(--l-text-secondary);
  line-height: 1.65;
  max-width: 440px;
  margin-bottom: 32px;
}

.section-mpcmds0i .lg-hero__actions {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.section-mpcmds0i .lg-hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--l-font-body);
  font-size: 15px;
  font-weight: 600;
  padding: 14px 32px;
  border-radius: var(--l-radius-md);
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
  border: none;
}

.section-mpcmds0i .lg-hero__btn--primary {
  background: var(--l-accent);
  color: #fff;
  box-shadow: 0 4px 16px rgba(196, 69, 54, 0.25);
}

.section-mpcmds0i .lg-hero__btn--primary:hover {
  background: var(--l-accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(196, 69, 54, 0.3);
  color: #fff;
  text-decoration: none;
}

.section-mpcmds0i .lg-hero__btn--ghost {
  background: transparent;
  color: var(--l-text);
  border: 2px solid var(--l-border);
}

.section-mpcmds0i .lg-hero__btn--ghost:hover {
  border-color: var(--l-accent);
  color: var(--l-accent);
  transform: translateY(-2px);
  text-decoration: none;
}

.section-mpcmds0i .lg-hero__phone {
  width: 280px;
  height: 580px;
  background: var(--l-primary);
  border-radius: 36px;
  padding: 12px;
  position: relative;
  box-shadow:
    0 20px 60px rgba(26, 26, 46, 0.15),
    0 0 0 1px rgba(30, 58, 95, 0.1),
    inset 0 0 0 1px rgba(245, 240, 232, 0.08);
  animation: section-mpcmds0i-float 6s ease-in-out infinite;
}

.section-mpcmds0i .lg-hero__phone-notch {
  position: absolute;
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  width: 120px;
  height: 28px;
  background: var(--l-primary);
  border-radius: 0 0 16px 16px;
  z-index: 3;
}

.section-mpcmds0i .lg-hero__phone-screen {
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #2A5280 0%, #1E3A5F 50%, #162D4A 100%);
  border-radius: 26px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

.section-mpcmds0i .lg-hero__app-header {
  padding: 40px 20px 20px;
  text-align: center;
}

.section-mpcmds0i .lg-hero__app-logo {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--l-text-light);
  font-family: var(--l-font-display);
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 12px;
}

.section-mpcmds0i .lg-hero__app-greeting {
  font-size: 24px;
  font-weight: 600;
  color: #fff;
  font-family: var(--l-font-display);
  line-height: 1.2;
}

.section-mpcmds0i .lg-hero__app-greeting small {
  display: block;
  font-size: 12px;
  font-weight: 400;
  opacity: 0.6;
  font-family: var(--l-font-body);
  margin-top: 4px;
}

.section-mpcmds0i .lg-hero__app-cards {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.section-mpcmds0i .lg-hero__app-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #fff;
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  animation: section-mpcmds0i-fade-up 0.6s ease backwards;
}

.section-mpcmds0i .lg-hero__app-card:nth-child(1) { animation-delay: 0.8s; }
.section-mpcmds0i .lg-hero__app-card:nth-child(2) { animation-delay: 1s; }
.section-mpcmds0i .lg-hero__app-card:nth-child(3) { animation-delay: 1.2s; }

.section-mpcmds0i .lg-hero__app-card-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-mpcmds0i .lg-hero__app-card-icon svg {
  width: 18px;
  height: 18px;
}

.section-mpcmds0i .lg-hero__app-card-icon--blue { background: rgba(42, 82, 128, 0.6); }
.section-mpcmds0i .lg-hero__app-card-icon--gold { background: rgba(212, 168, 83, 0.3); }
.section-mpcmds0i .lg-hero__app-card-icon--green { background: rgba(58, 157, 110, 0.3); }

.section-mpcmds0i .lg-hero__app-card-content {
  flex: 1;
  min-width: 0;
}

.section-mpcmds0i .lg-hero__app-card-title {
  font-size: 12px;
  font-weight: 600;
  line-height: 1.3;
}

.section-mpcmds0i .lg-hero__app-card-desc {
  font-size: 10px;
  opacity: 0.5;
  margin-top: 2px;
}

.section-mpcmds0i .lg-hero__app-card-bar {
  width: 48px;
  height: 4px;
  border-radius: 2px;
  background: rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
}

.section-mpcmds0i .lg-hero__app-card-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--l-accent-alt);
  width: 65%;
}

.section-mpcmds0i .lg-hero__app-bottom-nav {
  display: flex;
  justify-content: space-around;
  padding: 10px 16px 14px;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.section-mpcmds0i .lg-hero__app-nav-icon {
  width: 20px;
  height: 20px;
  opacity: 0.4;
  color: #fff;
  transition: opacity 0.3s ease;
}

.section-mpcmds0i .lg-hero__app-nav-icon--active {
  opacity: 0.9;
}

.section-mpcmds0i .lg-hero__app-nav-icon svg {
  width: 100%;
  height: 100%;
}

.section-mpcmds0i .lg-hero__phone-glow {
  position: absolute;
  width: 120%;
  height: 120%;
  top: -10%;
  left: -10%;
  background: radial-gradient(ellipse at 50% 50%, rgba(212, 168, 83, 0.06), transparent 60%);
  pointer-events: none;
  z-index: -1;
}

.section-mpcmds0i .lg-hero__stats {
  display: flex;
  gap: 40px;
  margin-top: 40px;
  padding-top: 32px;
  border-top: 1px solid var(--l-border-light);
}

.section-mpcmds0i .lg-hero__stat-item {
  text-align: center;
}

.section-mpcmds0i .lg-hero__stat-number {
  font-family: var(--l-font-display);
  font-size: 32px;
  font-weight: 700;
  color: var(--l-primary);
  line-height: 1.1;
  margin-bottom: 4px;
}

.section-mpcmds0i .lg-hero__stat-number span {
  color: var(--l-accent-alt);
  font-size: 20px;
}

.section-mpcmds0i .lg-hero__stat-label {
  font-size: 12px;
  color: var(--l-text-secondary);
  letter-spacing: 0.05em;
}

.section-mpcmds0i .lg-hero__scroll {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0.3;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--l-text-secondary);
}

.section-mpcmds0i .lg-hero__scroll-line {
  width: 1px;
  height: 32px;
  background: var(--l-text-secondary);
  animation: section-mpcmds0i-scroll-line 2s ease-in-out infinite;
}

@keyframes section-mpcmds0i-scroll-line {
  0%, 100% { opacity: 0.3; transform: scaleY(0.5); }
  50% { opacity: 1; transform: scaleY(1); }
}

/* ============================================================
   Responsive
   ============================================================ */

@media (max-width: 991px) {
  .section-mpcmds0i .lg-hero__inner {
    flex-direction: column;
    gap: 48px;
  }

  .section-mpcmds0i .lg-hero__text {
    max-width: 100%;
    text-align: center;
  }

  .section-mpcmds0i .lg-hero__subtitle {
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .section-mpcmds0i .lg-hero__actions {
    justify-content: center;
  }

  .section-mpcmds0i .lg-hero__stats {
    justify-content: center;
  }

  .section-mpcmds0i .lg-hero__title {
    font-size: 48px;
  }
}

@media (max-width: 767px) {
  .section-mpcmds0i .lg-hero {
    padding: 80px 0 60px;
  }

  .section-mpcmds0i .lg-hero__title {
    font-size: 36px;
  }

  .section-mpcmds0i .lg-hero__subtitle {
    font-size: 16px;
  }

  .section-mpcmds0i .lg-hero__phone {
    width: 240px;
    height: 500px;
  }

  .section-mpcmds0i .lg-hero__stats {
    flex-wrap: wrap;
    gap: 24px;
  }

  .section-mpcmds0i .lg-hero__scroll {
    display: none;
  }
}
</style>
{% endheader %}

<section class="section-mpcmds0i">
  <div class="lg-hero">
    <!-- Background -->
    <div class="lg-hero__bg-texture"></div>
    <div class="lg-hero__latitudes">
      <div class="lg-hero__latitudes-line"></div>
      <div class="lg-hero__latitudes-line"></div>
      <div class="lg-hero__latitudes-line"></div>
      <div class="lg-hero__latitudes-line"></div>
    </div>

    <!-- Globe decorative bg -->
    <div class="lg-hero__globe-bg">
      <svg viewBox="0 0 400 400" fill="none">
        <circle cx="200" cy="200" r="190" stroke="currentColor" stroke-width="0.5" opacity="0.3"/>
        <circle cx="200" cy="200" r="160" stroke="currentColor" stroke-width="0.3" opacity="0.2"/>
        <circle cx="200" cy="200" r="130" stroke="currentColor" stroke-width="0.3" opacity="0.15"/>
        <ellipse cx="200" cy="200" rx="190" ry="40" stroke="currentColor" stroke-width="0.3" opacity="0.15"/>
        <ellipse cx="200" cy="200" rx="190" ry="80" stroke="currentColor" stroke-width="0.3" opacity="0.12"/>
        <ellipse cx="200" cy="200" rx="40" ry="190" stroke="currentColor" stroke-width="0.3" opacity="0.12"/>
        <ellipse cx="200" cy="200" rx="80" ry="190" stroke="currentColor" stroke-width="0.3" opacity="0.1"/>
        <path d="M120 120 Q140 110 160 120 Q170 130 165 150 Q155 160 140 155 Q125 145 120 120Z" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.2"/>
        <path d="M240 140 Q260 135 280 145 Q290 160 285 180 Q270 185 255 175 Q245 160 240 140Z" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.2"/>
        <path d="M180 240 Q200 230 220 240 Q230 255 225 270 Q210 278 195 272 Q182 260 180 240Z" stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.2"/>
      </svg>
    </div>

    <!-- Compass rose -->
    <div class="lg-hero__compass">
      <svg viewBox="0 0 100 100" fill="none">
        <polygon points="50,5 56,42 95,50 56,58 50,95 44,58 5,50 44,42" fill="currentColor"/>
        <polygon points="50,5 56,42 50,50 44,42" fill="currentColor" opacity="0.5"/>
        <polygon points="50,95 44,58 50,50 56,58" fill="currentColor" opacity="0.3"/>
        <circle cx="50" cy="50" r="3" fill="currentColor" opacity="0.4"/>
      </svg>
    </div>

    <div class="lg-hero__content">
      <div class="container">
        <div class="lg-hero__inner">
          <div class="lg-hero__text">
            {% if this.Model.badge_text %}
            <div class="lg-hero__badge">
              <span class="lg-hero__badge-dot"></span>
              <span property="true" data-property="badge_text" method="text">{{this.Model.badge_text}}</span>
            </div>
            {% endif %}
            <h1 class="lg-hero__title">
              {% if this.Model.title_line_1 %}
              <span class="lg-hero__title-line" property="true" data-property="title_line_1" method="text">{{this.Model.title_line_1}}</span>
              {% endif %}
              {% if this.Model.title_line_2 %}
              <span class="lg-hero__title-line lg-hero__title-line--accent" property="true" data-property="title_line_2" method="text">{{this.Model.title_line_2}}</span>
              {% endif %}
            </h1>
            {% if this.Model.subtitle %}
            <p class="lg-hero__subtitle" property="true" data-property="subtitle" method="text">{{this.Model.subtitle}}</p>
            {% endif %}
            <div class="lg-hero__actions">
              {% if this.Model.btn_primary_text %}
              <a href="{% url this.Model.btn_primary_link %}" class="lg-hero__btn lg-hero__btn--primary" property="true" data-property="btn_primary_text" method="text">
                {{this.Model.btn_primary_text}}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              {% endif %}
              {% if this.Model.btn_ghost_text %}
              <a href="{% url this.Model.btn_ghost_link %}" class="lg-hero__btn lg-hero__btn--ghost" property="true" data-property="btn_ghost_text" method="text">{{this.Model.btn_ghost_text}}</a>
              {% endif %}
            </div>
            {% if this.Model.stats.size > 0 %}
            <div class="lg-hero__stats">
              {% assign index = 0 %}
              {% for stat in this.Model.stats %}
              <div class="lg-hero__stat-item">
                <div class="lg-hero__stat-number" property="true" data-property="stats[{{forloop.index0}}].number" method="text">{{stat.number}}{% if stat.suffix %}<span property="true" data-property="stats[{{forloop.index0}}].suffix" method="text">{{stat.suffix}}</span>{% endif %}</div>
                <div class="lg-hero__stat-label" property="true" data-property="stats[{{forloop.index0}}].label" method="text">{{stat.label}}</div>
              </div>
              {% endfor %}
            </div>
            {% endif %}
          </div>

          <div class="lg-hero__visual">
            <div class="lg-hero__phone">
              <div class="lg-hero__phone-notch"></div>
              <div class="lg-hero__phone-screen">
                <div class="lg-hero__app-header">
                  <div class="lg-hero__app-logo">
                    <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                      <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.2" fill="none"/>
                      <path d="M10 16c0 0 2-4 6-4s6 4 6 4-2 4-6 4-6-4-6-4z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    </svg>
                    Lingua
                  </div>
                  <div class="lg-hero__app-greeting">
                    Good Morning!
                    <small>Let's continue your lesson</small>
                  </div>
                </div>
                <div class="lg-hero__app-cards">
                  <div class="lg-hero__app-card">
                    <div class="lg-hero__app-card-icon lg-hero__app-card-icon--blue">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
                        <path d="M19 10v2a7 7 0 01-14 0v-2"/>
                      </svg>
                    </div>
                    <div class="lg-hero__app-card-content">
                      <div class="lg-hero__app-card-title">Pronunciation Drill</div>
                      <div class="lg-hero__app-card-desc">AI analysis ready</div>
                    </div>
