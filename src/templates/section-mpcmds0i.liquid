{% footer %}
<script type="text/javascript">
(function() {
  'use strict';
  var section = document.querySelector('.section-mpcmds0i');
  if (!section) return;

  // App card entrance stagger
  var cards = section.querySelectorAll('.lg-hero__app-card');
  cards.forEach(function(card, i) {
    card.style.opacity = '0';
    card.style.transform = 'translateY(16px)';
    card.style.transition = 'opacity 0.5s ease ' + (1 + i * 0.15) + 's, transform 0.5s ease ' + (1 + i * 0.15) + 's';
    setTimeout(function() {
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, 100);
  });

  // Parallax effect for globe decoration
  var globeBg = section.querySelector('.lg-hero__globe-bg');
  if (globeBg) {
    window.addEventListener('scroll', function() {
      var scrollY = window.scrollY;
      var speed = 0.15;
      var rect = section.getBoundingClientRect();
      if (rect.bottom > 0 && rect.top < window.innerHeight) {
        globeBg.style.transform = 'translateY(calc(-50% + ' + (scrollY * speed) + 'px))';
      }
    }, { passive: true });
  }
})();
</script>
{% endfooter %}
