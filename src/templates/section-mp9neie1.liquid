<!-- 页脚 -->
{% header %}
<style>
.section-mp9neie1 {
  background: #f0ebe3;
  padding: 6rem 0 3rem;
  border-top: 1px solid #e8e0d6;
}

.section-mp9neie1 .nn-footer__brand {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin-bottom: 1.6rem;
}

.section-mp9neie1 .nn-footer__brand-icon {
  color: #d94b2a;
  line-height: 1;
}

.section-mp9neie1 .nn-footer__brand-name {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2rem;
  font-weight: 700;
  color: #2c2823;
  letter-spacing: -0.02em;
}

.section-mp9neie1 .nn-footer__desc {
  font-size: 1.4rem;
  color: #8a7f73;
  line-height: 1.7;
  margin-bottom: 1.6rem;
  max-width: 30rem;
}

.section-mp9neie1 .nn-footer__social {
  display: flex;
  gap: 1rem;
}

.section-mp9neie1 .nn-footer__social-link {
  width: 3.6rem;
  height: 3.6rem;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #e8e0d6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a7f73;
  transition: all 0.3s ease;
}

.section-mp9neie1 .nn-footer__social-link:hover {
  color: #d94b2a;
  border-color: #d94b2a;
  background: #f5e8e4;
  text-decoration: none;
}

.section-mp9neie1 .nn-footer__social-link svg {
  width: 1.6rem;
  height: 1.6rem;
}

.section-mp9neie1 .nn-footer__heading {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: #2c2823;
  margin: 0 0 1.6rem;
  letter-spacing: -0.01em;
}

.section-mp9neie1 .nn-footer__links {
  list-style: none;
  padding: 0;
  margin: 0;
}

.section-mp9neie1 .nn-footer__links li {
  margin-bottom: 0.8rem;
}

.section-mp9neie1 .nn-footer__links li a {
  font-size: 1.4rem;
  color: #8a7f73;
  text-decoration: none;
  transition: color 0.3s ease;
}

.section-mp9neie1 .nn-footer__links li a:hover {
  color: #d94b2a;
  text-decoration: none;
}

.section-mp9neie1 .nn-footer__divider {
  height: 1px;
  background: #e8e0d6;
  margin: 3rem 0 2.4rem;
}

.section-mp9neie1 .nn-footer__copyright {
  font-size: 1.3rem;
  color: #8a7f73;
  margin: 0;
}

@media (max-width: 767px) {
  .section-mp9neie1 {
    padding: 4rem 0 2rem;
  }

  .section-mp9neie1 .nn-footer__brand,
  .section-mp9neie1 .nn-footer__desc,
  .section-mp9neie1 .nn-footer__social {
    text-align: center;
    justify-content: center;
    margin-left: auto;
    margin-right: auto;
  }

  .section-mp9neie1 .nn-footer__heading {
    margin-top: 2.4rem;
  }
}
</style>
{% endheader %}

<footer class="section-mp9neie1" id="footer">
  <div class="container">
    <div class="row">
      <div class="col-md-4">
        <div class="nn-footer__brand">
          <span class="nn-footer__brand-icon">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
              <path d="M6 4h14l8 8v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="2" fill="none"/>
              <path d="M20 4v8h8" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
          </span>
          {% if this.Model.brand_name %}
          <span class="nn-footer__brand-name" property="true" data-property="brand_name" method="text">{{this.Model.brand_name}}</span>
          {% endif %}
        </div>
        {% if this.Model.brand_desc %}
        <p class="nn-footer__desc" property="true" data-property="brand_desc" method="text">{{this.Model.brand_desc}}</p>
        {% endif %}
        <div class="nn-footer__social">
          <a href="#" class="nn-footer__social-link" aria-label="Twitter/X">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="nn-footer__social-link" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a href="#" class="nn-footer__social-link" aria-label="Discord">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
          </a>
        </div>
      </div>

      {% if this.Model.link_groups %}
      {% assign group_index = forloop.index0 %}
      {% for group in this.Model.link_groups %}
      <div class="col-md-2{% if forloop.first %} col-md-offset-1{% endif %}">
        {% if group.heading %}
        <h5 class="nn-footer__heading" property="true" data-property="link_groups[{{forloop.index0}}].heading" method="text">{{group.heading}}</h5>
        {% endif %}
        {% if group.links %}
        <ul class="nn-footer__links">
          {% assign link_index = forloop.index0 %}
          {% for link in group.links %}
          <li><a property="true" data-property="link_groups[{{forloop.index0}}].links[{{forloop.index0}}].text" method="text" href="{% url link.url %}">{{link.text}}</a></li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <div class="nn-footer__divider"></div>

    <div class="row">
      <div class="col-md-12 text-center">
        {% if this.Model.copyright %}
        <p class="nn-footer__copyright" property="true" data-property="copyright" method="text">{{this.Model.copyright}}</p>
        {% endif %}
      </div>
    </div>
  </div>
</footer>
