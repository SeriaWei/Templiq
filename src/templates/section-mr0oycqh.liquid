<!-- 低速刀盘 -->
{% header %}
<style>
.section-mr0oycqh {
    padding: 96px 0;
    background: #ede4d3;
    color: #251d16;
    font-family: Cambria, Georgia, serif;
}
.section-mr0oycqh .vm-burr__intro {
    display: flex;
    align-items: end;
    margin-bottom: 44px;
}
.section-mr0oycqh .vm-burr__kicker,
.section-mr0oycqh .vm-burr__text,
.section-mr0oycqh .vm-burr__card p,
.section-mr0oycqh .vm-burr__card span {
    font-family: "Trebuchet MS", Verdana, sans-serif;
}
.section-mr0oycqh .vm-burr__kicker {
    margin: 0 0 14px;
    color: #9a4d25;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
}
.section-mr0oycqh .vm-burr__title {
    margin: 0;
    font-size: 46px;
    line-height: 1.08;
    letter-spacing: 0;
}
.section-mr0oycqh .vm-burr__text {
    margin: 0;
    color: #665345;
    font-size: 16px;
    line-height: 1.85;
}
.section-mr0oycqh .vm-burr__grid {
    display: flex;
}
.section-mr0oycqh .vm-burr__card {
    min-height: 330px;
    padding: 36px;
    background: #f8f0df;
    border: 1px solid rgba(60, 44, 32, 0.14);
}
.section-mr0oycqh .vm-burr__card span {
    display: inline-block;
    margin-bottom: 56px;
    color: #b05e2e;
    font-size: 12px;
    font-weight: 700;
}
.section-mr0oycqh .vm-burr__card h3 {
    margin: 0 0 18px;
    font-size: 28px;
}
.section-mr0oycqh .vm-burr__card p {
    margin: 0;
    color: #665345;
    font-size: 15px;
    line-height: 1.75;
}
.section-mr0oycqh .vm-burr__card--image {
    padding: 0;
    overflow: hidden;
}
.section-mr0oycqh .vm-burr__card--image img {
    display: block;
    width: 100%;
    height: 330px;
    object-fit: cover;
}
@media (max-width: 991px) {
    .section-mr0oycqh .vm-burr__intro,
    .section-mr0oycqh .vm-burr__grid { display: block; }
    .section-mr0oycqh .vm-burr__text { margin-top: 22px; }
    .section-mr0oycqh .vm-burr__card { min-height: auto; margin-bottom: 18px; }
}
@media (max-width: 767px) {
    .section-mr0oycqh { padding: 64px 0; }
    .section-mr0oycqh .vm-burr__title { font-size: 34px; }
}
</style>
{% endheader %}

<section class="section-mr0oycqh" id="{{this.Model.anchor_id}}">
    <div class="container">
        <div class="row vm-burr__intro">
            <div class="col-md-5 col-sm-6">
                {% if this.Model.kicker %}<p class="vm-burr__kicker" property="true" data-property="kicker" method="text">{{this.Model.kicker}}</p>{% endif %}
                {% if this.Model.title %}<h2 class="vm-burr__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>{% endif %}
            </div>
            <div class="col-md-6 col-md-offset-1 col-sm-6">
                {% if this.Model.text %}<p class="vm-burr__text" property="true" data-property="text" method="text">{{this.Model.text}}</p>{% endif %}
            </div>
        </div>
        <div class="row vm-burr__grid">
            {% for card in this.Model.cards %}
            <div class="col-md-4 col-sm-4">
                <article class="vm-burr__card{% if card.image_src != empty %} vm-burr__card--image{% endif %}">
                    {% if card.image_src != empty %}
                    <img property="true" data-property="cards[{{forloop.index0}}].image_src" method="attr" para="src" src="{% url card.image_src %}" alt="{{card.image_alt}}">
                    {% else %}
                    {% if card.number %}<span property="true" data-property="cards[{{forloop.index0}}].number" method="text">{{card.number}}</span>{% endif %}
                    {% if card.title %}<h3 property="true" data-property="cards[{{forloop.index0}}].title" method="text">{{card.title}}</h3>{% endif %}
                    {% if card.text %}<p property="true" data-property="cards[{{forloop.index0}}].text" method="text">{{card.text}}</p>{% endif %}
                    {% endif %}
                </article>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
