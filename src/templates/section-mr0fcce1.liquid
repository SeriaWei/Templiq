<!-- Auralith H7 耳机展示 -->
{% header %}
<style>
.section-mr0fcce1 {
    position: relative;
    min-height: 100vh;
    padding: 72px 0 56px;
    overflow: hidden;
    color: #1d2420;
    background:
        radial-gradient(circle at 12% 18%, rgba(220, 72, 41, 0.2), transparent 250px),
        radial-gradient(circle at 86% 20%, rgba(52, 92, 86, 0.34), transparent 340px),
        linear-gradient(118deg, #f1eadb 0%, #e5dccb 46%, #203934 46.2%, #182724 100%);
    font-family: Candara, Corbel, "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 16px;
}

.section-mr0fcce1 .ah-showcase__texture {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    pointer-events: none;
    background-image:
        repeating-linear-gradient(100deg, rgba(255, 255, 255, 0.2) 0 1px, transparent 1px 9px),
        radial-gradient(circle at 70% 70%, rgba(0, 0, 0, 0.25) 0 1px, transparent 1px);
    background-size: auto, 10px 10px;
    mix-blend-mode: multiply;
}

.section-mr0fcce1 .ah-showcase__layout {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    min-height: 580px;
}

.section-mr0fcce1 .ah-showcase__copy {
    max-width: 570px;
    animation: section-mr0fcce1-slideUp 780ms ease both;
}

.section-mr0fcce1 .ah-showcase__eyebrow,
.section-mr0fcce1 .ah-sound-card__label {
    margin: 0 0 18px;
    color: #bd442e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
}

.section-mr0fcce1 .ah-showcase__title {
    margin: 0;
    color: #1d2420;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 78px;
    line-height: 0.94;
    font-weight: 400;
    letter-spacing: 0;
}

.section-mr0fcce1 .ah-showcase__lead {
    max-width: 490px;
    margin: 28px 0 0;
    color: #4d554f;
    font-size: 18px;
    line-height: 1.76;
}

.section-mr0fcce1 .ah-showcase__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 34px 0 0;
}

.section-mr0fcce1 .ah-showcase__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 138px;
    min-height: 48px;
    padding: 0 21px;
    border: 1px solid #1d2420;
    color: #1d2420;
    text-decoration: none;
    font-weight: 700;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease;
}

.section-mr0fcce1 .ah-showcase__button:hover,
.section-mr0fcce1 .ah-showcase__button:focus {
    color: #1d2420;
    text-decoration: none;
    transform: translateY(-2px);
}

.section-mr0fcce1 .ah-showcase__button--primary {
    background: #1d2420;
    color: #f7eddb;
}

.section-mr0fcce1 .ah-showcase__button--primary:hover,
.section-mr0fcce1 .ah-showcase__button--primary:focus {
    border-color: #bd442e;
    background: #bd442e;
    color: #fff7eb;
}

.section-mr0fcce1 .ah-showcase__button--ghost:hover,
.section-mr0fcce1 .ah-showcase__button--ghost:focus {
    background: rgba(255, 255, 255, 0.48);
}

.section-mr0fcce1 .ah-showcase__stage {
    position: relative;
    min-height: 580px;
    animation: section-mr0fcce1-floatIn 880ms 120ms ease both;
}

.section-mr0fcce1 .ah-showcase__image--main {
    position: absolute;
    top: 14px;
    right: 0;
    width: min(45vw, 530px);
    height: 580px;
    object-fit: cover;
    filter: saturate(0.72) contrast(1.08);
    box-shadow: -22px 22px 0 #bd442e, 0 30px 80px rgba(0, 0, 0, 0.34);
}

.section-mr0fcce1 .ah-showcase__chip {
    position: absolute;
    z-index: 3;
    width: 158px;
    padding: 15px 16px;
    border: 1px solid rgba(247, 237, 219, 0.54);
    background: rgba(24, 39, 36, 0.9);
    color: #e9e3d5;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

.section-mr0fcce1 .ah-showcase__chip span {
    display: block;
    margin-bottom: 3px;
    color: #f3b36a;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 34px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: none;
}

.section-mr0fcce1 .ah-showcase__chip--top {
    top: 60px;
    left: -14px;
}

.section-mr0fcce1 .ah-showcase__chip--bottom {
    right: 42px;
    bottom: 40px;
}

.section-mr0fcce1 .ah-showcase__lower {
    position: relative;
    z-index: 2;
    margin-top: 24px;
}

.section-mr0fcce1 .ah-sound-card {
    display: grid;
    grid-template-columns: minmax(190px, 0.78fr) 1fr;
    min-height: 320px;
    background: rgba(248, 241, 229, 0.88);
    box-shadow: 0 24px 60px rgba(29, 36, 32, 0.17);
}

.section-mr0fcce1 .ah-sound-card__image {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    filter: saturate(0.78) contrast(1.05);
}

.section-mr0fcce1 .ah-sound-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 38px;
}

.section-mr0fcce1 .ah-sound-card__title {
    margin: 0;
    color: #1d2420;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 36px;
    line-height: 1.08;
    font-weight: 400;
    letter-spacing: 0;
}

.section-mr0fcce1 .ah-sound-card__text {
    margin: 20px 0 0;
    color: #5c655d;
    font-size: 16px;
    line-height: 1.72;
}

.section-mr0fcce1 .ah-feature-list {
    height: 100%;
    display: grid;
    gap: 12px;
}

.section-mr0fcce1 .ah-feature-list__item {
    padding: 24px 26px;
    border-left: 3px solid #bd442e;
    background: rgba(28, 45, 41, 0.9);
    color: #e9e3d5;
}

.section-mr0fcce1 .ah-feature-list__item span {
    color: #f3b36a;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 24px;
}

.section-mr0fcce1 .ah-feature-list__item h3 {
    margin: 8px 0 0;
    font-size: 20px;
    font-weight: 700;
}

.section-mr0fcce1 .ah-feature-list__item p {
    margin: 10px 0 0;
    color: rgba(233, 227, 213, 0.76);
    font-size: 15px;
    line-height: 1.65;
}

.section-mr0fcce1 .ah-specs {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin: 40px 0 0;
    background: #f8f1e5;
    box-shadow: 0 20px 50px rgba(29, 36, 32, 0.13);
}

.section-mr0fcce1 .ah-specs div {
    min-height: 124px;
    padding: 26px 24px;
    border-right: 1px solid rgba(29, 36, 32, 0.14);
}

.section-mr0fcce1 .ah-specs div:last-child {
    border-right: 0;
}

.section-mr0fcce1 .ah-specs dt {
    color: #1d2420;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 38px;
    line-height: 1;
    font-weight: 400;
}

.section-mr0fcce1 .ah-specs dd {
    margin: 10px 0 0;
    color: #667068;
    font-size: 14px;
}

@keyframes section-mr0fcce1-slideUp {
    from {
        opacity: 0;
        transform: translateY(22px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes section-mr0fcce1-floatIn {
    from {
        opacity: 0;
        transform: translate(18px, 24px) scale(0.98);
    }

    to {
        opacity: 1;
        transform: translate(0, 0) scale(1);
    }
}

@media (max-width: 991px) {
    .section-mr0fcce1 {
        padding: 54px 0 44px;
        background:
            radial-gradient(circle at 18% 12%, rgba(220, 72, 41, 0.22), transparent 240px),
            linear-gradient(180deg, #f1eadb 0%, #e7decd 52%, #203934 52.2%, #182724 100%);
    }

    .section-mr0fcce1 .ah-showcase__layout {
        display: block;
        min-height: 0;
    }

    .section-mr0fcce1 .ah-showcase__title {
        font-size: 61px;
    }

    .section-mr0fcce1 .ah-showcase__stage {
        min-height: 480px;
        margin-top: 46px;
    }

    .section-mr0fcce1 .ah-showcase__image--main {
        width: 82%;
        height: 470px;
        right: 5%;
    }

    .section-mr0fcce1 .ah-showcase__chip--top {
        left: 10px;
    }

    .section-mr0fcce1 .ah-sound-card {
        margin-bottom: 18px;
    }

    .section-mr0fcce1 .ah-specs {
        grid-template-columns: repeat(2, 1fr);
    }

    .section-mr0fcce1 .ah-specs div:nth-child(2) {
        border-right: 0;
    }
}

@media (max-width: 767px) {
    .section-mr0fcce1 {
        padding: 42px 0 34px;
    }

    .section-mr0fcce1 .ah-showcase__title {
        font-size: 46px;
        line-height: 1;
    }

    .section-mr0fcce1 .ah-showcase__lead {
        font-size: 16px;
    }

    .section-mr0fcce1 .ah-showcase__button {
        width: 100%;
    }

    .section-mr0fcce1 .ah-showcase__stage {
        min-height: 390px;
    }

    .section-mr0fcce1 .ah-showcase__image--main {
        width: 86%;
        height: 370px;
        box-shadow: -12px 12px 0 #bd442e, 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .section-mr0fcce1 .ah-showcase__chip {
        width: 132px;
        padding: 12px;
    }

    .section-mr0fcce1 .ah-showcase__chip span {
        font-size: 27px;
    }

    .section-mr0fcce1 .ah-showcase__chip--bottom {
        right: 8px;
        bottom: 26px;
    }

    .section-mr0fcce1 .ah-sound-card {
        display: block;
    }

    .section-mr0fcce1 .ah-sound-card__image {
        height: 240px;
        min-height: 0;
    }

    .section-mr0fcce1 .ah-sound-card__content,
    .section-mr0fcce1 .ah-feature-list__item,
    .section-mr0fcce1 .ah-specs div {
        padding: 24px 20px;
    }

    .section-mr0fcce1 .ah-sound-card__title {
        font-size: 30px;
    }

    .section-mr0fcce1 .ah-specs {
        grid-template-columns: 1fr;
    }

    .section-mr0fcce1 .ah-specs div,
    .section-mr0fcce1 .ah-specs div:nth-child(2) {
        min-height: 108px;
        border-right: 0;
        border-bottom: 1px solid rgba(29, 36, 32, 0.14);
    }

    .section-mr0fcce1 .ah-specs div:last-child {
        border-bottom: 0;
    }
}
</style>
{% endheader %}

<section class="section-mr0fcce1" aria-labelledby="section-mr0fcce1-title">
    <div class="ah-showcase__texture"></div>
    <div class="container">
        <div class="row ah-showcase__layout">
            <div class="col-md-6 col-sm-7">
                <div class="ah-showcase__copy">
                    {% if this.Model.eyebrow %}
                    <p class="ah-showcase__eyebrow" property="true" data-property="eyebrow" method="text">{{this.Model.eyebrow}}</p>
                    {% endif %}
                    {% if this.Model.heading %}
                    <h2 id="section-mr0fcce1-title" class="ah-showcase__title" property="true" data-property="heading" method="text">{{this.Model.heading}}</h2>
                    {% endif %}
                    {% if this.Model.lead %}
                    <p class="ah-showcase__lead" property="true" data-property="lead" method="text">{{this.Model.lead}}</p>
                    {% endif %}
                    <div class="ah-showcase__actions" aria-label="产品操作">
                        {% if this.Model.primary_text %}
                        <a class="ah-showcase__button ah-showcase__button--primary" property="true" data-property="primary_link" method="attr" para="href" href="{% url this.Model.primary_link %}">{{this.Model.primary_text}}</a>
                        {% endif %}
                        {% if this.Model.secondary_text %}
                        <a class="ah-showcase__button ah-showcase__button--ghost" property="true" data-property="secondary_link" method="attr" para="href" href="{% url this.Model.secondary_link %}">{{this.Model.secondary_text}}</a>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-sm-5">
                <div class="ah-showcase__stage" aria-label="Auralith H7 产品展示">
                    {% if this.Model.hero_image %}
                    <img class="ah-showcase__image--main" property="true" data-property="hero_image" method="attr" para="src" src="{% url this.Model.hero_image %}" alt="{{this.Model.hero_image_alt}}">
                    {% endif %}
                    {% if this.Model.top_badge_value or this.Model.top_badge_label %}
                    <div class="ah-showcase__chip ah-showcase__chip--top">
                        {% if this.Model.top_badge_value %}<span property="true" data-property="top_badge_value" method="text">{{this.Model.top_badge_value}}</span>{% endif %}
                        {% if this.Model.top_badge_label %}<span property="true" data-property="top_badge_label" method="text">{{this.Model.top_badge_label}}</span>{% endif %}
                    </div>
                    {% endif %}
                    {% if this.Model.bottom_badge_value or this.Model.bottom_badge_label %}
                    <div class="ah-showcase__chip ah-showcase__chip--bottom">
                        {% if this.Model.bottom_badge_value %}<span property="true" data-property="bottom_badge_value" method="text">{{this.Model.bottom_badge_value}}</span>{% endif %}
                        {% if this.Model.bottom_badge_label %}<span property="true" data-property="bottom_badge_label" method="text">{{this.Model.bottom_badge_label}}</span>{% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="row ah-showcase__lower">
            <div class="col-md-7">
                <div class="ah-sound-card">
                    {% if this.Model.profile_image %}
                    <img class="ah-sound-card__image" property="true" data-property="profile_image" method="attr" para="src" src="{% url this.Model.profile_image %}" alt="{{this.Model.profile_image_alt}}">
                    {% endif %}
                    <div class="ah-sound-card__content">
                        {% if this.Model.profile_label %}
                        <p class="ah-sound-card__label" property="true" data-property="profile_label" method="text">{{this.Model.profile_label}}</p>
                        {% endif %}
                        {% if this.Model.profile_heading %}
                        <h3 class="ah-sound-card__title" property="true" data-property="profile_heading" method="text">{{this.Model.profile_heading}}</h3>
                        {% endif %}
                        {% if this.Model.profile_text %}
                        <p class="ah-sound-card__text" property="true" data-property="profile_text" method="text">{{this.Model.profile_text}}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="col-md-5">
                {% if this.Model.features.size > 0 %}
                <div class="ah-feature-list">
                    {% for item in this.Model.features %}
                    <article class="ah-feature-list__item">
                        {% if item.number %}<span property="true" data-property="features[{{forloop.index0}}].number" method="text">{{item.number}}</span>{% endif %}
                        {% if item.title %}<h3 property="true" data-property="features[{{forloop.index0}}].title" method="text">{{item.title}}</h3>{% endif %}
                        {% if item.description %}<p property="true" data-property="features[{{forloop.index0}}].description" method="text">{{item.description}}</p>{% endif %}
                    </article>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>

        {% if this.Model.specs.size > 0 %}
        <dl id="product-specs" class="ah-specs" aria-label="Auralith H7 规格">
            {% for item in this.Model.specs %}
            <div>
                {% if item.value %}<dt property="true" data-property="specs[{{forloop.index0}}].value" method="text">{{item.value}}</dt>{% endif %}
                {% if item.label %}<dd property="true" data-property="specs[{{forloop.index0}}].label" method="text">{{item.label}}</dd>{% endif %}
            </div>
            {% endfor %}
        </dl>
        {% endif %}
    </div>
</section>
