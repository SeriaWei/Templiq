<!-- 主视觉 -->
{% header %}
<style>
.section-mp9t3osg {
  --sr-bg: #0e0b08;
  --sr-surface: #1a1612;
  --sr-surface-raised: #24201a;
  --sr-border: #332e27;
  --sr-text: #e8e2d8;
  --sr-text-secondary: #9c9488;
  --sr-accent-gold: #c9a84e;
  --sr-accent-gold-soft: rgba(201, 168, 78, 0.12);
  --sr-accent-ruby: #8b2f3f;
  --sr-font-heading: Georgia, "Times New Roman", Times, serif;
  --sr-font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --sr-font-mono: "SF Mono", "Fira Code", Consolas, monospace;
  font-size: 10px;
  background: var(--sr-bg);
  color: var(--sr-text);
  font-family: var(--sr-font-body);
}

.section-mp9t3osg .sr-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding-top: 80px;
  background: var(--sr-bg);
}
.section-mp9t3osg .sr-hero__bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
}
.section-mp9t3osg .sr-hero__gradient {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 700px 500px at 30% 20%, rgba(201, 168, 78, 0.04) 0%, transparent 60%),
    radial-gradient(ellipse 500px 600px at 70% 80%, rgba(139, 47, 63, 0.03) 0%, transparent 60%),
    radial-gradient(ellipse 400px 400px at 50% 50%, rgba(201, 168, 78, 0.02) 0%, transparent 50%);
}
.section-mp9t3osg .sr-hero__noise {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0.25;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  background-size: 256px 256px;
  pointer-events: none;
}
.section-mp9t3osg .sr-hero__orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
}
.section-mp9t3osg .sr-hero__orb--1 {
  width: 400px; height: 400px;
  top: -10%; right: -5%;
  background: radial-gradient(circle, rgba(201, 168, 78, 0.06) 0%, transparent 70%);
  animation: mp9t3osg-orbFloat 12s ease-in-out infinite;
}
.section-mp9t3osg .sr-hero__orb--2 {
  width: 300px; height: 300px;
  bottom: -5%; left: -5%;
  background: radial-gradient(circle, rgba(139, 47, 63, 0.04) 0%, transparent 70%);
  animation: mp9t3osg-orbFloat 15s ease-in-out infinite reverse;
}
@keyframes mp9t3osg-orbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -30px) scale(1.05); }
  66% { transform: translate(-20px, 20px) scale(0.95); }
}
.section-mp9t3osg .sr-hero__content {
  position: relative;
  z-index: 3;
  padding: 60px 0 100px;
  width: 100%;
}
.section-mp9t3osg .sr-hero__label {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-family: var(--sr-font-heading);
  font-size: 12px;
  font-weight: 400;
  font-style: italic;
  color: var(--sr-accent-gold);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 32px;
}
.section-mp9t3osg .sr-hero__label-line {
  display: inline-block;
  width: 40px;
  height: 1px;
  background: var(--sr-accent-gold);
  opacity: 0.5;
}
.section-mp9t3osg .sr-hero__title { margin: 0 0 28px; }
.section-mp9t3osg .sr-hero__title-word {
  display: inline-block;
  font-family: var(--sr-font-heading);
  font-size: 72px;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--sr-text);
  margin: 0 0.15em;
}
.section-mp9t3osg .sr-hero__title-word--accent {
  color: var(--sr-accent-gold);
  font-style: italic;
  position: relative;
}
.section-mp9t3osg .sr-hero__title-word--accent::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  bottom: 8px;
  height: 3px;
  background: var(--sr-accent-gold);
  opacity: 0.3;
  border-radius: 2px;
}
.section-mp9t3osg .sr-hero__subtitle {
  font-size: 18px;
  line-height: 1.7;
  color: var(--sr-text-secondary);
  max-width: 640px;
  margin: 0 auto 36px;
}
.section-mp9t3osg .sr-hero__actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}
.section-mp9t3osg .sr-hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 600;
  padding: 12px 28px;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.3s ease;
  letter-spacing: 0.02em;
}
.section-mp9t3osg .sr-hero__btn--primary {
  color: var(--sr-bg);
  background: var(--sr-accent-gold);
}
.section-mp9t3osg .sr-hero__btn--primary:hover {
  background: #dbb956;
  color: var(--sr-bg);
  text-decoration: none;
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(201, 168, 78, 0.35);
}
.section-mp9t3osg .sr-hero__btn--outline {
  color: var(--sr-text);
  border: 1px solid var(--sr-border);
}
.section-mp9t3osg .sr-hero__btn--outline:hover {
  border-color: var(--sr-accent-gold);
  color: var(--sr-accent-gold);
  text-decoration: none;
  transform: translateY(-2px);
}
.section-mp9t3osg .sr-hero__scroll {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.section-mp9t3osg .sr-hero__scroll span {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--sr-text-secondary);
  opacity: 0.5;
}
.section-mp9t3osg .sr-hero__scroll-line {
  width: 1px;
  height: 30px;
  background: linear-gradient(to bottom, var(--sr-accent-gold), transparent);
  animation: mp9t3osg-scrollPulse 2s ease-in-out infinite;
}
@keyframes mp9t3osg-scrollPulse {
  0%, 100% { opacity: 1; transform: scaleY(1); transform-origin: top; }
  50% { opacity: 0.3; transform: scaleY(0.5); transform-origin: top; }
}
@keyframes mp9t3osg-fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@media (max-width: 768px) {
  .section-mp9t3osg .sr-hero__title-word { font-size: 48px; }
  .section-mp9t3osg .sr-hero__subtitle { font-size: 16px; padding: 0 16px; }
  .section-mp9t3osg .sr-hero__label { font-size: 10px; }
  .section-mp9t3osg .sr-hero__actions { flex-direction: column; width: 100%; padding: 0 16px; }
  .section-mp9t3osg .sr-hero__btn { width: 100%; justify-content: center; }
  .section-mp9t3osg .sr-hero__scroll { display: none; }
}
@media (max-width: 480px) {
  .section-mp9t3osg .sr-hero__title-word { font-size: 36px; }
}
</style>
{% endheader %}

<div class="section-mp9t3osg">
<section class="sr-hero" id="hero">
  <div class="sr-hero__bg">
    <div class="sr-hero__gradient"></div>
    <div class="sr-hero__noise"></div>
    <div class="sr-hero__orb sr-hero__orb--1"></div>
    <div class="sr-hero__orb sr-hero__orb--2"></div>
  </div>
  <div class="sr-hero__content">
    <div class="container">
      <div class="row">
        <div class="col-md-8 col-md-offset-2 text-center">
          {% if this.Model.label %}
          <div class="sr-hero__label">
            <span class="sr-hero__label-line"></span>
            <span property="true" data-property="label" method="text">{{this.Model.label}}</span>
            <span class="sr-hero__label-line"></span>
          </div>
          {% endif %}
          <h1 class="sr-hero__title">
            {% if this.Model.title_1 %}<span class="sr-hero__title-word" property="true" data-property="title_1" method="text">{{this.Model.title_1}}</span>{% endif %}
            {% if this.Model.title_2 %}<span class="sr-hero__title-word sr-hero__title-word--accent" property="true" data-property="title_2" method="text">{{this.Model.title_2}}</span>{% endif %}
            {% if this.Model.title_3 %}<span class="sr-hero__title-word" property="true" data-property="title_3" method="text">{{this.Model.title_3}}</span>{% endif %}
            {% if this.Model.title_4 %}<span class="sr-hero__title-word" property="true" data-property="title_4" method="text">{{this.Model.title_4}}</span>{% endif %}
          </h1>
          {% if this.Model.subtitle %}
          <p class="sr-hero__subtitle" property="true" data-property="subtitle" method="text">{{this.Model.subtitle}}</p>
          {% endif %}
          <div class="sr-hero__actions">
            {% if this.Model.primary_btn_text %}
            <a property="true" data-property="primary_btn_href" method="attr" para="href" href="{% url this.Model.primary_btn_href %}" class="sr-hero__btn sr-hero__btn--primary">
              <span property="true" data-property="primary_btn_text" method="text">{{this.Model.primary_btn_text}}</span>
              {{this.Model.primary_btn_svg | raw}}
            </a>
            {% endif %}
            {% if this.Model.secondary_btn_text %}
            <a property="true" data-property="secondary_btn_href" method="attr" para="href" href="{% url this.Model.secondary_btn_href %}" class="sr-hero__btn sr-hero__btn--outline">
              <span property="true" data-property="secondary_btn_text" method="text">{{this.Model.secondary_btn_text}}</span>
            </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% if this.Model.scroll_text %}
  <div class="sr-hero__scroll">
    <span property="true" data-property="scroll_text" method="text">{{this.Model.scroll_text}}</span>
    <div class="sr-hero__scroll-line"></div>
  </div>
  {% endif %}
</section>
</div>
