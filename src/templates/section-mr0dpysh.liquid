<!-- 云线茶园 -->
{% header %}
<style>
.section-mr0dpysh {
    --tea-ink: #172416;
    --tea-ink-soft: #4d6047;
    --tea-leaf: #526f2d;
    --tea-leaf-dark: #294315;
    --tea-lime: #d8e86e;
    --tea-paper: #f8f3df;
    --tea-rice: #fffaf0;
    --tea-line: rgba(23, 36, 22, .16);
    color: var(--tea-ink);
    background: var(--tea-paper);
    font-family: "Songti SC", "STSong", "Noto Serif CJK SC", Georgia, serif;
    font-size: 16px;
    line-height: 1.65;
}

.section-mr0dpysh .gt-origin {
    padding: 70px 0 90px;
}

.section-mr0dpysh .gt-origin__grid {
    display: flex;
    align-items: stretch;
}

.section-mr0dpysh .gt-kicker {
    margin: 0 0 14px;
    color: var(--tea-leaf-dark);
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
}

.section-mr0dpysh .gt-section-title {
    margin: 0;
    color: var(--tea-ink);
    font-size: clamp(32px, 5vw, 62px);
    line-height: 1.04;
    font-weight: 500;
    letter-spacing: 0;
}

.section-mr0dpysh .gt-origin__panel {
    position: relative;
    min-height: 580px;
    overflow: hidden;
    border: 1px solid var(--tea-line);
    background: var(--tea-rice);
}

.section-mr0dpysh .gt-origin__panel img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(.18) saturate(.85) contrast(1.08);
}

.section-mr0dpysh .gt-origin__panel:after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(23,36,22,.82), rgba(23,36,22,.18) 50%, rgba(248,243,223,.7));
}

.section-mr0dpysh .gt-origin__map {
    position: absolute;
    z-index: 1;
    top: 70px;
    right: 70px;
    width: 230px;
    height: 230px;
    border-radius: 50%;
    border: 1px solid rgba(255,250,240,.7);
}

.section-mr0dpysh .gt-origin__pin {
    position: absolute;
    left: 48%;
    top: 42%;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--tea-lime);
    box-shadow: 0 0 0 12px rgba(216,232,110,.24);
}

.section-mr0dpysh .gt-origin__contour {
    position: absolute;
    border: 1px solid rgba(255,250,240,.5);
    border-radius: 48% 52% 44% 56%;
    transform: rotate(-18deg);
}

.section-mr0dpysh .gt-origin__contour--one { inset: 30px; }
.section-mr0dpysh .gt-origin__contour--two { inset: 56px 42px 40px 60px; }
.section-mr0dpysh .gt-origin__contour--three { inset: 80px 70px 70px 50px; }

.section-mr0dpysh .gt-origin__facts {
    position: absolute;
    z-index: 2;
    left: 30px;
    bottom: 30px;
    width: calc(100% - 60px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: rgba(255,250,240,.42);
}

.section-mr0dpysh .gt-origin__facts article {
    min-height: 170px;
    padding: 20px;
    background: rgba(255,250,240,.86);
}

.section-mr0dpysh .gt-origin__facts span {
    display: block;
    color: var(--tea-leaf);
    font-family: Georgia, serif;
    font-size: 30px;
}

.section-mr0dpysh .gt-origin__facts strong {
    display: block;
    margin-top: 10px;
    font-size: 18px;
}

.section-mr0dpysh .gt-origin__facts p {
    margin: 9px 0 0;
    color: var(--tea-ink-soft);
}

.section-mr0dpysh .gt-reveal {
    opacity: 0;
    transform: translateY(22px);
    animation: section-mr0dpysh-rise .75s cubic-bezier(.2, .8, .2, 1) forwards;
}

@keyframes section-mr0dpysh-rise {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 991px) {
    .section-mr0dpysh .gt-origin__grid {
        display: block;
    }

    .section-mr0dpysh .gt-origin__panel {
        margin-top: 30px;
    }
}

@media (max-width: 767px) {
    .section-mr0dpysh .gt-origin {
        padding: 50px 0;
    }

    .section-mr0dpysh .gt-section-title {
        font-size: clamp(30px, 13vw, 48px);
    }

    .section-mr0dpysh .gt-origin__panel {
        min-height: 760px;
    }

    .section-mr0dpysh .gt-origin__map {
        top: 30px;
        right: 30px;
        width: 160px;
        height: 160px;
    }

    .section-mr0dpysh .gt-origin__facts {
        grid-template-columns: 1fr;
        left: 16px;
        bottom: 16px;
        width: calc(100% - 32px);
    }
}
</style>
{% endheader %}

<div class="section-mr0dpysh">
    <section class="gt-origin" aria-labelledby="originTitle-mr0dpysh">
        <div class="container">
            <div class="row gt-origin__grid">
                <div class="col-md-4 col-sm-12 gt-reveal">
                    {% if this.Model.kicker %}<p class="gt-kicker" property="true" data-property="kicker" method="text">{{this.Model.kicker}}</p>{% endif %}
                    {% if this.Model.title %}<h2 id="originTitle-mr0dpysh" class="gt-section-title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>{% endif %}
                </div>
                <div class="col-md-8 col-sm-12 gt-reveal" style="animation-delay: .1s;">
                    <div class="gt-origin__panel">
                        {% if this.Model.image %}<img property="true" data-property="image" method="attr" para="src" src="{% url this.Model.image %}" alt="{{this.Model.image_alt}}">{% endif %}
                        <div class="gt-origin__map" aria-hidden="true">
                            <span class="gt-origin__pin"></span>
                            <span class="gt-origin__contour gt-origin__contour--one"></span>
                            <span class="gt-origin__contour gt-origin__contour--two"></span>
                            <span class="gt-origin__contour gt-origin__contour--three"></span>
                        </div>
                        {% if this.Model.facts %}
                        <div class="gt-origin__facts" aria-label="产地信息">
                            {% for fact in this.Model.facts %}
                            <article>
                                {% if fact.number %}<span property="true" data-property="facts[{{forloop.index0}}].number" method="text">{{fact.number}}</span>{% endif %}
                                {% if fact.title %}<strong property="true" data-property="facts[{{forloop.index0}}].title" method="text">{{fact.title}}</strong>{% endif %}
                                {% if fact.description %}<p property="true" data-property="facts[{{forloop.index0}}].description" method="text">{{fact.description}}</p>{% endif %}
                            </article>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
