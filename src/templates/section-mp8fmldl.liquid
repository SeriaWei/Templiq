<!-- 产品中心 -->
{% header %}
<style>
.cm-section-label { font-size: 1.2rem; font-weight: 500; color: #00d4ff; letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 1.2rem; display: inline-block; font-family: 'Orbitron', sans-serif; }
.cm-text-gradient { color: transparent; background: linear-gradient(135deg, #00d4ff, #7c3aed); -webkit-background-clip: text; background-clip: text; }
.cm-product-card__tag { font-family: 'Orbitron', sans-serif; }
.cm-products__title, .cm-products__intro, .cm-product-card__title, .cm-product-card__desc, .cm-product-card__specs li, .cm-product-card__link { font-family: 'Noto Sans SC', sans-serif; }
.cm-products {
  position: relative;
  padding: 0 0 10rem;
  background: #070b17;
}
.cm-products__title {
  font-size: 4.2rem;
  font-weight: 700;
  color: #e8edf5;
  margin-bottom: 1.6rem;
  letter-spacing: 0.04em;
}
.cm-products__intro {
  font-size: 1.7rem;
  font-weight: 300;
  color: #8899b4;
  max-width: 54rem;
  margin: 0 auto 5rem;
  line-height: 1.7;
}
.cm-products__grid { margin-top: 1rem; }
.cm-product-card {
  background: linear-gradient(160deg, rgba(12, 19, 38, 0.8), rgba(7, 11, 23, 0.9));
  border: 1px solid rgba(255, 255, 255, 0.04);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  margin-bottom: 3rem;
  position: relative;
}
.cm-product-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.3), transparent);
  opacity: 0;
  transition: opacity 0.4s ease;
}
.cm-product-card:hover {
  transform: translateY(-6px);
  border-color: rgba(0, 212, 255, 0.12);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
}
.cm-product-card:hover::before { opacity: 1; }
.cm-product-card--featured {
  border-color: rgba(0, 212, 255, 0.1);
  background: linear-gradient(160deg, rgba(12, 19, 38, 0.9), rgba(7, 11, 23, 0.95));
  box-shadow: 0 0 40px rgba(0, 212, 255, 0.05);
}
.cm-product-card--featured::after {
  content: '推荐';
  position: absolute;
  top: 1.6rem; right: -3rem;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #070b17;
  font-size: 1.1rem;
  font-weight: 700;
  padding: 0.4rem 3.6rem;
  transform: rotate(45deg);
  letter-spacing: 0.08em;
  z-index: 2;
}
.cm-product-card__visual {
  position: relative;
  padding: 4rem 3rem 2rem;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}
.cm-product-card__icon {
  width: 8rem;
  height: 8rem;
  color: #00d4ff;
  position: relative;
  z-index: 2;
  transition: all 0.4s ease;
}
.cm-product-card:hover .cm-product-card__icon { transform: scale(1.1) rotate(-3deg); color: #33ddff; }
.cm-product-card__glow {
  position: absolute;
  width: 12rem; height: 12rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.1), transparent 70%);
  animation: glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.2); opacity: 1; }
}
.cm-product-card__body { padding: 0 2.4rem 3rem; }
.cm-product-card__tag {
  display: inline-block;
  font-size: 1rem;
  font-weight: 500;
  color: #00d4ff;
  background: rgba(0, 212, 255, 0.08);
  border: 1px solid rgba(0, 212, 255, 0.12);
  padding: 0.3rem 1.2rem;
  border-radius: 50px;
  margin-bottom: 1.2rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.cm-product-card__tag--hot {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.08);
  border-color: rgba(245, 158, 11, 0.2);
}
.cm-product-card__title {
  font-size: 2.2rem;
  font-weight: 700;
  color: #e8edf5;
  margin-bottom: 1rem;
  letter-spacing: 0.02em;
}
.cm-product-card__desc {
  font-size: 1.4rem;
  font-weight: 300;
  color: #8899b4;
  line-height: 1.7;
  margin-bottom: 1.6rem;
}
.cm-product-card__specs {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem;
}
.cm-product-card__specs li {
  font-size: 1.3rem;
  color: #6b7a99;
  padding: 0.4rem 0 0.4rem 1.6rem;
  position: relative;
  letter-spacing: 0.02em;
}
.cm-product-card__specs li::before {
  content: '▸';
  position: absolute;
  left: 0;
  color: #00d4ff;
  opacity: 0.5;
}
.cm-product-card__link {
  font-size: 1.4rem;
  font-weight: 500;
  color: #00d4ff;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  transition: gap 0.3s ease;
}
.cm-product-card__link:hover { color: #33ddff; text-decoration: none; gap: 1rem; }
.cm-product-card__link span { transition: transform 0.3s ease; }
.cm-product-card__link:hover span { transform: translateX(4px); }
@media (max-width: 767px) {
  .cm-products { padding: 0 0 5rem; }
  .cm-products__title { font-size: 3rem; }
  .cm-product-card__visual { padding: 3rem 2rem 1.5rem; }
  .cm-product-card__body { padding: 0 1.8rem 2rem; }
}
</style>
{% endheader %}

<section class="cm-products">
  <div class="container">
    <div class="row">
      <div class="col-md-12 text-center">
        <h6 class="cm-section-label" property="true" data-property="section_label" method="text">{{this.Model.section_label}}</h6>
        <h2 class="cm-products__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>
        {% if this.Model.intro %}
        <p class="cm-products__intro" property="true" data-property="intro" method="text">{{this.Model.intro}}</p>
        {% endif %}
      </div>
    </div>
    <div class="row cm-products__grid">
      {% for product in this.Model.products %}
      {% if product.featured %}
      <div class="col-md-4 col-sm-6">
        <div class="cm-product-card cm-product-card--featured">
      {% else %}
      <div class="col-md-4 col-sm-6">
        <div class="cm-product-card">
      {% endif %}
          <div class="cm-product-card__visual">
            <div class="cm-product-card__icon">
              {{product.svg_icon | raw}}
            </div>
            <div class="cm-product-card__glow"></div>
          </div>
          <div class="cm-product-card__body">
            {% assign p_idx = forloop.index0 %}
            <span class="cm-product-card__tag{% if product.tag_hot %} cm-product-card__tag--hot{% endif %}" property="true" data-property="products[{{p_idx}}].tag" method="text">{{product.tag}}</span>
            <h3 class="cm-product-card__title" property="true" data-property="products[{{p_idx}}].title" method="text">{{product.title}}</h3>
            <p class="cm-product-card__desc" property="true" data-property="products[{{p_idx}}].desc" method="text">{{product.desc}}</p>
            {% if product.specs %}
            <ul class="cm-product-card__specs">
              {% for spec_item in product.specs %}
              <li property="true" data-property="products[{{p_idx}}].specs[{{forloop.index0}}].spec" method="text">{{spec_item.spec}}</li>
              {% endfor %}
            </ul>
            {% endif %}
            <a property="true" data-property="products[{{p_idx}}].link" method="attr" para="href" href="{% url product.link %}" class="cm-product-card__link">
              {{product.link_text}} <span>→</span>
            </a>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
