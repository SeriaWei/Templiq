<!-- 关于我们 -->
{% header %}
<style>
.cm-section-label, .cm-about__floating-badge-num, .cm-about__stat-num, .cm-about__stat-suffix { font-family: 'Orbitron', sans-serif; }
.cm-about__title, .cm-about__desc, .cm-about__stat-label, .cm-about__floating-badge-label { font-family: 'Noto Sans SC', sans-serif; }
.cm-about {
  position: relative;
  padding: 12rem 0 0;
  background: #070b17;
  overflow: hidden;
}
.cm-section-label {
  font-size: 1.2rem;
  font-weight: 500;
  color: #00d4ff;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  margin-bottom: 1.2rem;
  display: inline-block;
}
.cm-text-gradient {
  color: transparent;
  background: linear-gradient(135deg, #00d4ff, #7c3aed);
  -webkit-background-clip: text;
  background-clip: text;
}
.cm-about__image-wrapper {
  position: relative;
  margin-bottom: 4rem;
}
.cm-about__image {
  width: 100%;
  height: auto;
  border-radius: 16px;
  display: block;
  position: relative;
  z-index: 2;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}
.cm-about__image-decoration {
  position: absolute;
  top: -2rem;
  right: -2rem;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.cm-about__image-ring {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  border: 1px solid rgba(0, 212, 255, 0.15);
  border-radius: 20px;
}
.cm-about__floating-badge {
  position: absolute;
  bottom: -2rem;
  right: -1rem;
  z-index: 3;
  background: linear-gradient(135deg, rgba(7, 11, 23, 0.95), rgba(12, 19, 38, 0.95));
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 12px;
  padding: 1.6rem 2.4rem;
  text-align: center;
  backdrop-filter: blur(10px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}
.cm-about__floating-badge-num {
  display: block;
  font-size: 3.2rem;
  font-weight: 700;
  color: #00d4ff;
  line-height: 1;
}
.cm-about__floating-badge-label {
  display: block;
  font-size: 1.2rem;
  color: #8899b4;
  margin-top: 0.4rem;
  letter-spacing: 0.08em;
}
.cm-about__content {
  padding-top: 2rem;
}
.cm-about__title {
  font-size: 4rem;
  font-weight: 700;
  line-height: 1.2;
  color: #e8edf5;
  margin-bottom: 2.4rem;
  letter-spacing: 0.04em;
}
.cm-about__desc {
  font-size: 1.6rem;
  font-weight: 300;
  line-height: 1.8;
  color: #8899b4;
  margin-bottom: 1.6rem;
}
.cm-about__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.6rem;
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}
.cm-about__stat {
  text-align: center;
  position: relative;
}
.cm-about__stat-num {
  display: block;
  font-size: 3.6rem;
  font-weight: 700;
  color: #e8edf5;
  line-height: 1;
  margin-bottom: 0.4rem;
}
.cm-about__stat-label {
  display: block;
  font-size: 1.2rem;
  color: #8899b4;
  letter-spacing: 0.06em;
}
.cm-about__stat-suffix {
  font-size: 2.4rem;
  font-weight: 700;
  color: #00d4ff;
  position: absolute;
  top: 0;
  right: -0.4rem;
}
.cm-about__divider {
  position: relative;
  width: 100%;
  height: 80px;
  margin-top: -1px;
  overflow: hidden;
}
.cm-about__divider svg {
  width: 100%;
  height: 100%;
  display: block;
}
@media (max-width: 767px) {
  .cm-about { padding: 6rem 0 0; }
  .cm-about__title { font-size: 3rem; }
  .cm-about__stats { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
}
</style>
{% endheader %}

<section class="cm-about">
  <div class="container">
    <div class="row">
      <div class="col-md-5">
        <div class="cm-about__image-wrapper">
          <img property="true" data-property="image_src" method="attr" para="src" src="{% url this.Model.image_src %}" alt="{{this.Model.image_alt}}" class="cm-about__image" loading="lazy">
          <div class="cm-about__image-decoration">
            <div class="cm-about__image-ring"></div>
          </div>
          <div class="cm-about__floating-badge">
            <span class="cm-about__floating-badge-num">{{this.Model.badge_num}}</span>
            <span class="cm-about__floating-badge-label">{{this.Model.badge_label}}</span>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-md-offset-1">
        <div class="cm-about__content">
          {% if this.Model.section_label %}
          <h6 class="cm-section-label" property="true" data-property="section_label" method="text">{{this.Model.section_label}}</h6>
          {% endif %}
          <h2 class="cm-about__title">
            {% if this.Model.title_line1 %}<span property="true" data-property="title_line1" method="text">{{this.Model.title_line1}}</span><br>{% endif %}
            {% if this.Model.title_line2 %}
            <span class="cm-text-gradient" property="true" data-property="title_line2" method="text">{{this.Model.title_line2}}</span>
            {% endif %}
          </h2>
          {% if this.Model.desc1 %}
          <p class="cm-about__desc" property="true" data-property="desc1" method="text">{{this.Model.desc1}}</p>
          {% endif %}
          {% if this.Model.desc2 %}
          <p class="cm-about__desc" property="true" data-property="desc2" method="text">{{this.Model.desc2}}</p>
          {% endif %}
          {% if this.Model.stats %}
          {% assign stat_idx = 0 %}
          <div class="cm-about__stats">
            {% for stat in this.Model.stats %}
            <div class="cm-about__stat">
              <span class="cm-about__stat-num" data-count="{{stat.num}}">{{stat.num}}</span>
              <span class="cm-about__stat-label" property="true" data-property="stats[{{stat_idx}}].label" method="text">{{stat.label}}</span>
              {% if stat.suffix %}<span class="cm-about__stat-suffix">{{stat.suffix}}</span>{% endif %}
            </div>
            {% assign stat_idx = stat_idx | plus: 1 %}
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  <div class="cm-about__divider">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 Q180,0 360,40 Q540,80 720,40 Q900,0 1080,40 Q1260,80 1440,40 L1440,80 L0,80 Z" fill="#070b17"/>
    </svg>
  </div>
</section>
