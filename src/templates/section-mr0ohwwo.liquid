<!-- 山径跑鞋首屏 -->
{% header %}
<style>
.section-mr0ohwwo {
    position: relative;
    overflow: hidden;
    min-height: 720px;
    padding: 82px 0 76px;
    background: #e9e0d0;
    color: #141612;
    font-family: Georgia, "Times New Roman", serif;
}

.section-mr0ohwwo .rv-hero__terrain {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(135deg, rgba(22, 30, 20, 0.18) 0 1px, transparent 1px 34px),
        radial-gradient(circle at 12% 20%, rgba(216, 76, 42, 0.28), transparent 28%),
        radial-gradient(circle at 86% 18%, rgba(38, 76, 54, 0.22), transparent 26%),
        linear-gradient(160deg, #e9e0d0 0%, #d8ccb7 54%, #b7c0a4 100%);
    opacity: 0.95;
}

.section-mr0ohwwo .rv-hero__layout {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
}

.section-mr0ohwwo .rv-hero__copy {
    max-width: 620px;
    padding-top: 34px;
}

.section-mr0ohwwo .rv-hero__eyebrow {
    display: inline-block;
    margin: 0 0 24px;
    padding: 9px 14px;
    border: 1px solid rgba(20, 22, 18, 0.38);
    border-radius: 999px;
    background: rgba(233, 224, 208, 0.72);
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.section-mr0ohwwo .rv-hero__title {
    margin: 0;
    max-width: 620px;
    color: #141612;
    font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
    font-size: 74px;
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0;
}

.section-mr0ohwwo .rv-hero__lead {
    max-width: 560px;
    margin: 28px 0 0;
    color: #394033;
    font-size: 18px;
    line-height: 1.8;
}

.section-mr0ohwwo .rv-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
}

.section-mr0ohwwo .rv-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 0;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 13px;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 220ms ease, background 220ms ease, color 220ms ease;
}

.section-mr0ohwwo .rv-hero__button:hover,
.section-mr0ohwwo .rv-hero__button:focus {
    transform: translateY(-2px);
    text-decoration: none;
}

.section-mr0ohwwo .rv-hero__button--primary {
    border: 1px solid #141612;
    background: #141612;
    color: #f7f0df;
}

.section-mr0ohwwo .rv-hero__button--ghost {
    border: 1px solid #141612;
    background: rgba(247, 240, 223, 0.38);
    color: #141612;
}

.section-mr0ohwwo .rv-hero__photo {
    position: relative;
    margin: 0 0 0 auto;
    max-width: 520px;
    transform: rotate(-3deg);
}

.section-mr0ohwwo .rv-hero__photo::before {
    content: "";
    position: absolute;
    inset: 26px -24px -24px 24px;
    border: 2px solid #d84c2a;
    z-index: 0;
}

.section-mr0ohwwo .rv-hero__photo img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 620px;
    object-fit: cover;
    filter: saturate(1.05) contrast(1.04);
    box-shadow: 0 36px 80px rgba(34, 34, 23, 0.22);
}

.section-mr0ohwwo .rv-hero__photo figcaption {
    position: absolute;
    right: -20px;
    bottom: 28px;
    z-index: 2;
    padding: 11px 14px;
    background: #d84c2a;
    color: #fff8eb;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
}

@media (max-width: 991px) {
    .section-mr0ohwwo {
        min-height: 0;
        padding: 56px 0;
    }

    .section-mr0ohwwo .rv-hero__layout {
        display: block;
    }

    .section-mr0ohwwo .rv-hero__title {
        font-size: 58px;
    }

    .section-mr0ohwwo .rv-hero__photo {
        margin: 44px 0 0;
        max-width: none;
    }

    .section-mr0ohwwo .rv-hero__photo img {
        height: 440px;
    }
}

@media (max-width: 640px) {
    .section-mr0ohwwo .rv-hero__title {
        font-size: 44px;
    }

    .section-mr0ohwwo .rv-hero__lead {
        font-size: 16px;
    }

    .section-mr0ohwwo .rv-hero__photo img {
        height: 340px;
    }
}
</style>
{% endheader %}

<section class="section-mr0ohwwo">
    <div class="rv-hero__terrain" aria-hidden="true"></div>
    <div class="container">
        <div class="row rv-hero__layout">
            <div class="col-md-6 col-sm-7">
                <div class="rv-hero__copy">
                    {% if this.Model.eyebrow %}
                    <p property="true" data-property="eyebrow" method="text" class="rv-hero__eyebrow">{{this.Model.eyebrow}}</p>
                    {% endif %}
                    {% if this.Model.title %}
                    <h1 property="true" data-property="title" method="text" class="rv-hero__title">{{this.Model.title}}</h1>
                    {% endif %}
                    {% if this.Model.lead %}
                    <p property="true" data-property="lead" method="text" class="rv-hero__lead">{{this.Model.lead}}</p>
                    {% endif %}
                    <div class="rv-hero__actions">
                        {% if this.Model.primary_text and this.Model.primary_link %}
                        <a property="true" data-property="primary_link" method="attr" para="href" href="{% url this.Model.primary_link %}" class="rv-hero__button rv-hero__button--primary"><span property="true" data-property="primary_text" method="text">{{this.Model.primary_text}}</span></a>
                        {% endif %}
                        {% if this.Model.secondary_text and this.Model.secondary_link %}
                        <a property="true" data-property="secondary_link" method="attr" para="href" href="{% url this.Model.secondary_link %}" class="rv-hero__button rv-hero__button--ghost"><span property="true" data-property="secondary_text" method="text">{{this.Model.secondary_text}}</span></a>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-sm-5">
                {% if this.Model.hero_image %}
                <figure class="rv-hero__photo">
                    <img property="true" data-property="hero_image" method="attr" para="src" src="{% url this.Model.hero_image %}" alt="{{this.Model.hero_alt}}">
                    {% if this.Model.spec_line %}
                    <figcaption property="true" data-property="spec_line" method="text">{{this.Model.spec_line}}</figcaption>
                    {% endif %}
                </figure>
                {% endif %}
            </div>
        </div>
    </div>
</section>
