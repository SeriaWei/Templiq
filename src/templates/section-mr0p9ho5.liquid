<!-- 首发预约套装 -->
{% header %}
<style>
.section-mr0p9ho5 {
    padding: 92px 0 104px;
    background: linear-gradient(90deg, rgba(255, 110, 58, 0.12) 0 1px, transparent 1px 42px), #1f4f4a;
    color: #fff3dc;
    font-family: "Gill Sans", "Trebuchet MS", sans-serif;
}
.section-mr0p9ho5 .la-order__shell {
    padding: 52px;
    border: 1px solid rgba(255, 243, 220, 0.34);
    background: rgba(23, 19, 15, 0.24);
}
.section-mr0p9ho5 .la-order__kicker {
    margin: 0 0 20px;
    color: #ffba5d;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-mr0p9ho5 .la-order__title {
    margin: 0;
    font-family: Didot, "Bodoni 72", Georgia, serif;
    font-size: 52px;
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
}
.section-mr0p9ho5 .la-order__copy {
    max-width: 680px;
    margin: 24px 0 0;
    color: rgba(255, 243, 220, 0.78);
    font-size: 18px;
    line-height: 1.85;
}
.section-mr0p9ho5 .la-order__price {
    min-height: 260px;
    padding: 30px;
    border: 1px solid rgba(255, 243, 220, 0.36);
    background: #fff3dc;
    color: #17130f;
}
.section-mr0p9ho5 .la-order__price span {
    display: block;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 13px;
    text-transform: uppercase;
}
.section-mr0p9ho5 .la-order__price strong {
    display: block;
    margin: 20px 0 28px;
    font-family: Didot, "Bodoni 72", Georgia, serif;
    font-size: 58px;
    line-height: 1;
}
.section-mr0p9ho5 .la-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    width: 100%;
    padding: 0 24px;
    border: 1px solid #17130f;
    border-radius: 0;
    background: #17130f;
    color: #fff3dc;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 13px;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 220ms ease;
}
.section-mr0p9ho5 .la-button:hover,
.section-mr0p9ho5 .la-button:focus {
    transform: translateY(-2px);
    color: #fff3dc;
    text-decoration: none;
}
@media (max-width: 767px) {
    .section-mr0p9ho5 {
        padding: 64px 0;
    }
    .section-mr0p9ho5 .la-order__shell {
        padding: 28px;
    }
    .section-mr0p9ho5 .la-order__price {
        margin-top: 30px;
    }
    .section-mr0p9ho5 .la-order__title {
        font-size: 38px;
    }
}
</style>
{% endheader %}

<section class="section-mr0p9ho5">
    <div class="container">
        <div class="la-order__shell">
            <div class="row">
                <div class="col-md-7 col-sm-7">
                    {% if this.Model.eyebrow %}
                    <p class="la-order__kicker" property="true" data-property="eyebrow" method="text">{{this.Model.eyebrow}}</p>
                    {% endif %}
                    {% if this.Model.title %}
                    <h2 class="la-order__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>
                    {% endif %}
                    {% if this.Model.copy %}
                    <p class="la-order__copy" property="true" data-property="copy" method="text">{{this.Model.copy}}</p>
                    {% endif %}
                </div>
                <div class="col-md-5 col-sm-5">
                    <div class="la-order__price">
                        {% if this.Model.price_label %}
                        <span property="true" data-property="price_label" method="text">{{this.Model.price_label}}</span>
                        {% endif %}
                        {% if this.Model.price %}
                        <strong property="true" data-property="price" method="text">{{this.Model.price}}</strong>
                        {% endif %}
                        {% if this.Model.button_text %}
                        <a class="la-button" property="true" data-property="button_link" method="attr" para="href" href="{% url this.Model.button_link %}">{{this.Model.button_text}}</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
