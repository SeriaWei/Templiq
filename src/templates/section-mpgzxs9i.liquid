<!-- 联系方式 -->
{% header %}
<style>

.section-mpgzxs9i {
  --mx-bg-alt: #111827;
  --mx-text: #E8EDF5;
  --mx-text-secondary: #8896A8;
  --mx-accent: #D4A84B;
  --mx-font-display: 'Cinzel', 'Georgia', serif;
  --mx-font-body: 'Jost', 'Helvetica Neue', Arial, sans-serif;
  font-family: var(--mx-font-body);
  color: var(--mx-text);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.section-mpgzxs9i .mx-section__label {
  font-family: var(--mx-font-display);
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--mx-accent);
  margin-bottom: 16px;
  font-weight: 500;
  display: inline-block;
}

.section-mpgzxs9i .mx-section__label::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 1px;
  background: var(--mx-accent);
  margin-right: 12px;
  vertical-align: middle;
  position: relative;
  top: -1px;
}

.section-mpgzxs9i .mx-section__heading {
  font-family: var(--mx-font-display);
  font-size: 38px;
  font-weight: 700;
  color: var(--mx-text);
  margin: 0 0 16px;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.section-mpgzxs9i .mx-section__sub {
  font-size: 17px;
  color: var(--mx-text-secondary);
  max-width: 600px;
  margin: 0 auto;
  font-weight: 400;
  line-height: 1.6;
  text-align: center;
}

.section-mpgzxs9i .mx-contact {
  position: relative;
  padding: 100px 0;
  background: var(--mx-bg-alt);
}

.section-mpgzxs9i .mx-contact__bg-texture {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 10% 90%, rgba(212, 168, 75, 0.02) 0%, transparent 50%),
    radial-gradient(ellipse at 90% 10%, rgba(212, 168, 75, 0.02) 0%, transparent 50%);
  pointer-events: none;
}

.section-mpgzxs9i .mx-contact__inner {
  position: relative;
  z-index: 2;
}

.section-mpgzxs9i .mx-contact__header {
  text-align: center;
  margin-bottom: 0;
}

@media (max-width: 768px) {
  .section-mpgzxs9i .mx-contact {
    padding: 60px 0;
  }
  .section-mpgzxs9i .mx-section__heading {
    font-size: 26px;
  }
}
</style>
{% endheader %}

<section class="section-mpgzxs9i">
  <div class="mx-contact">
    <div class="mx-contact__bg-texture"></div>
    <div class="container">
      <div class="row">
        <div class="col-xs-12 col-md-8 col-md-offset-2">
          <div class="mx-contact__inner">
            <div class="mx-contact__header">
              {% if this.Model.section_label %}<div class="mx-section__label" property="true" data-property="section_label" method="text">{{this.Model.section_label}}</div>{% endif %}
              {% if this.Model.heading %}<h2 class="mx-section__heading" property="true" data-property="heading" method="text">{{this.Model.heading}}</h2>{% endif %}
              {% if this.Model.subtitle %}<p class="mx-section__sub" property="true" data-property="subtitle" method="text">{{this.Model.subtitle}}</p>{% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
