<!-- 核心优势 -->
{% header %}
<style>
.section-mpfeczfz {
  --neon-cyan: #00f5ff;
  --neon-purple: #bf00ff;
  --dark-bg: #0a0a0f;
  --card-bg: rgba(20, 20, 30, 0.8);
  --text-main: #e0e0e0;
  --text-muted: #888899;
  background: var(--dark-bg);
  padding: 100px 0;
  font-family: 'Courier New', monospace;
}

.section-mpfeczfz .ssd-features__title {
  font-size: 40px;
  text-align: center;
  margin-bottom: 60px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: bold;
}

.section-mpfeczfz .ssd-features__accent {
  color: var(--neon-cyan);
}

.section-mpfeczfz .ssd-features__grid {
  margin-top: 0;
}

.section-mpfeczfz .ssd-feature-card {
  background: var(--card-bg);
  border: 1px solid rgba(0, 245, 255, 0.1);
  padding: 40px 30px;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  margin-bottom: 30px;
}

.section-mpfeczfz .ssd-feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.section-mpfeczfz .ssd-feature-card:hover::before {
  transform: scaleX(1);
}

.section-mpfeczfz .ssd-feature-card:hover {
  transform: translateY(-10px);
  border-color: rgba(0, 245, 255, 0.4);
  box-shadow: 0 20px 40px rgba(0, 245, 255, 0.2);
}

.section-mpfeczfz .ssd-feature-card__icon {
  width: 80px;
  height: 80px;
  border: 2px solid var(--neon-cyan);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  position: relative;
}

.section-mpfeczfz .ssd-feature-card__icon svg {
  width: 40px;
  height: 40px;
  color: var(--neon-cyan);
}

.section-mpfeczfz .ssd-feature-card__icon::before {
  content: '';
  position: absolute;
  top: 5px;
  left: 5px;
  right: 5px;
  bottom: 5px;
  border: 1px solid rgba(0, 245, 255, 0.3);
}

.section-mpfeczfz .ssd-feature-card__title {
  font-size: 22px;
  margin-bottom: 15px;
  color: white;
}

.section-mpfeczfz .ssd-feature-card__desc {
  color: var(--text-muted);
  font-size: 15px;
  line-height: 1.8;
  margin-bottom: 20px;
}

.section-mpfeczfz .ssd-feature-card__metric {
  font-size: 30px;
  font-weight: bold;
  color: var(--neon-cyan);
}

.section-mpfeczfz .ssd-feature-card__metric-unit {
  font-size: 16px;
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .section-mpfeczfz .ssd-features__title {
    font-size: 30px;
  }
}
</style>
{% endheader %}

<div class="section-mpfeczfz">
<div class="container">
  <div class="row">
    <div class="col-md-12 text-center">
      <h2 class="ssd-features__title">
        <span property="true" data-property="section_title" method="text">{{this.Model.section_title}}</span>
      </h2>
    </div>
  </div>

  <div class="row ssd-features__grid">
    {% if this.Model.features and this.Model.features.size > 0 %}
    {% assign index = 0 %}
    {% for item in this.Model.features %}
    <div class="col-md-3 col-sm-6">
      <div class="ssd-feature-card">
        {% if item.icon_svg %}
        <div class="ssd-feature-card__icon">{{item.icon_svg}}</div>
        {% endif %}
        {% if item.title %}
        <h3 class="ssd-feature-card__title" property="true" data-property="features[{{index}}].title" method="text">{{item.title}}</h3>
        {% endif %}
        {% if item.description %}
        <p class="ssd-feature-card__desc" property="true" data-property="features[{{index}}].description" method="text">{{item.description}}</p>
        {% endif %}
        {% if item.metric_value %}
        <div class="ssd-feature-card__metric">
          <span property="true" data-property="features[{{index}}].metric_value" method="text">{{item.metric_value}}</span>
          {% if item.metric_unit %}
          <span class="ssd-feature-card__metric-unit" property="true" data-property="features[{{index}}].metric_unit" method="text">{{item.metric_unit}}</span>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
    {% assign index = index | plus: 1 %}
    {% endfor %}
    {% endif %}
  </div>
</div>
</div>