<!-- 采摘节奏 -->
{% header %}
<style>
.section-mr0polm0 {
    padding: 98px 0 104px;
    background: linear-gradient(135deg, rgba(24, 34, 29, 0.08) 0 1px, transparent 1px 38px), #d7cfba;
    color: #18221d;
    font-family: "Avenir Next", "Gill Sans", "Trebuchet MS", sans-serif;
}
.section-mr0polm0 .vd-ritual__layout {
    display: flex;
    align-items: stretch;
}
.section-mr0polm0 .vd-ritual__kicker {
    margin: 0 0 18px;
    color: #24554b;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-mr0polm0 .vd-ritual__title {
    margin: 0;
    font-family: Cambria, Georgia, serif;
    font-size: 52px;
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: 0;
}
.section-mr0polm0 .vd-ritual__copy {
    max-width: 520px;
    margin: 24px 0 0;
    color: #35463e;
    font-size: 18px;
    line-height: 1.85;
}
.section-mr0polm0 .vd-ritual__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    height: 100%;
}
.section-mr0polm0 .vd-ritual__steps article {
    display: flex;
    min-height: 360px;
    padding: 26px;
    flex-direction: column;
    justify-content: flex-end;
    background: #f6f0df;
    border-top: 6px solid #24554b;
    box-shadow: 0 22px 54px rgba(24, 34, 29, 0.12);
}
.section-mr0polm0 .vd-ritual__steps article:nth-child(2) {
    transform: translateY(34px);
    border-top-color: #d3ee6d;
}
.section-mr0polm0 .vd-ritual__steps span {
    margin-bottom: auto;
    color: #24554b;
    font-family: "Lucida Console", Monaco, monospace;
    font-size: 13px;
}
.section-mr0polm0 .vd-ritual__steps h3 {
    margin: 0 0 14px;
    font-family: Cambria, Georgia, serif;
    font-size: 30px;
    line-height: 1.05;
}
.section-mr0polm0 .vd-ritual__steps p {
    margin: 0;
    color: #4d5d55;
    font-size: 16px;
    line-height: 1.7;
}
@media (max-width: 991px) {
    .section-mr0polm0 .vd-ritual__layout {
        display: block;
    }
    .section-mr0polm0 .vd-ritual__steps {
        margin-top: 36px;
    }
}
@media (max-width: 767px) {
    .section-mr0polm0 {
        padding: 68px 0;
    }
    .section-mr0polm0 .vd-ritual__title {
        font-size: 38px;
    }
    .section-mr0polm0 .vd-ritual__steps {
        grid-template-columns: 1fr;
    }
    .section-mr0polm0 .vd-ritual__steps article,
    .section-mr0polm0 .vd-ritual__steps article:nth-child(2) {
        min-height: 230px;
        transform: none;
    }
}
</style>
{% endheader %}

<section class="section-mr0polm0">
    <div class="container">
        <div class="row vd-ritual__layout">
            <div class="col-md-5 col-sm-6">
                {% if this.Model.eyebrow %}<p class="vd-ritual__kicker" property="true" data-property="eyebrow" method="text">{{this.Model.eyebrow}}</p>{% endif %}
                {% if this.Model.title %}<h2 class="vd-ritual__title" property="true" data-property="title" method="text">{{this.Model.title}}</h2>{% endif %}
                {% if this.Model.copy %}<p class="vd-ritual__copy" property="true" data-property="copy" method="text">{{this.Model.copy}}</p>{% endif %}
            </div>
            <div class="col-md-7 col-sm-6">
                {% if this.Model.steps.size > 0 %}
                <div class="vd-ritual__steps">
                    {% for item in this.Model.steps %}
                    <article>
                        {% if item.time %}<span property="true" data-property="steps[{{forloop.index0}}].time" method="text">{{item.time}}</span>{% endif %}
                        {% if item.title %}<h3 property="true" data-property="steps[{{forloop.index0}}].title" method="text">{{item.title}}</h3>{% endif %}
                        {% if item.copy %}<p property="true" data-property="steps[{{forloop.index0}}].copy" method="text">{{item.copy}}</p>{% endif %}
                    </article>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
