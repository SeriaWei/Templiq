<!-- 用户评价 -->
{% header %}
<style>
.section-mp9nehth {
  padding: 10rem 0;
  background: #ffffff;
  position: relative;
}

.section-mp9nehth .nn-testimonials__title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 4.4rem;
  font-weight: 700;
  color: #2c2823;
  margin: 0 0 5rem;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.section-mp9nehth .nn-testimonials__carousel {
  position: relative;
}

.section-mp9nehth .nn-testimonial {
  display: none;
  text-align: center;
  padding: 0 2rem;
}

.section-mp9nehth .nn-testimonial.active {
  display: block;
  animation: nnFadeInUp 0.6s ease both;
}

.section-mp9nehth .nn-testimonial__quote-mark {
  width: 4rem;
  height: 4rem;
  margin: 0 auto 2rem;
  color: #d94b2a;
  opacity: 0.3;
}

.section-mp9nehth .nn-testimonial__quote-mark svg {
  width: 100%;
  height: 100%;
}

.section-mp9nehth .nn-testimonial__text {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 2.4rem;
  font-weight: 400;
  line-height: 1.6;
  color: #2c2823;
  max-width: 70rem;
  margin: 0 auto 3rem;
  font-style: italic;
  letter-spacing: -0.01em;
}

.section-mp9nehth .nn-testimonial__author {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.2rem;
}

.section-mp9nehth .nn-testimonial__avatar {
  width: 5.2rem;
  height: 5.2rem;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid #e8e0d6;
}

.section-mp9nehth .nn-testimonial__name {
  display: block;
  font-size: 1.5rem;
  font-weight: 600;
  color: #2c2823;
}

.section-mp9nehth .nn-testimonial__role {
  display: block;
  font-size: 1.3rem;
  color: #8a7f73;
  margin-top: 0.2rem;
}

.section-mp9nehth .nn-testimonials__controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  margin-top: 4rem;
}

.section-mp9nehth .nn-testimonials__btn {
  width: 4.4rem;
  height: 4.4rem;
  border-radius: 50%;
  border: 1.5px solid #e8e0d6;
  background: #ffffff;
  color: #2c2823;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.section-mp9nehth .nn-testimonials__btn:hover {
  border-color: #d94b2a;
  color: #d94b2a;
  background: #f5e8e4;
}

.section-mp9nehth .nn-testimonials__btn svg {
  width: 1.8rem;
  height: 1.8rem;
}

.section-mp9nehth .nn-testimonials__dots {
  display: flex;
  gap: 0.8rem;
}

.section-mp9nehth .nn-testimonials__dots span {
  width: 0.8rem;
  height: 0.8rem;
  border-radius: 50%;
  background: #e8e0d6;
  cursor: pointer;
  transition: all 0.3s ease;
}

.section-mp9nehth .nn-testimonials__dots span.active {
  background: #d94b2a;
  transform: scale(1.3);
}

.section-mp9nehth .nn-section-label {
  display: inline-block;
  font-size: 1.2rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: #d94b2a;
  margin-bottom: 1.6rem;
  position: relative;
}

.section-mp9nehth .nn-section-label::before,
.section-mp9nehth .nn-section-label::after {
  content: '';
  display: inline-block;
  width: 2.4rem;
  height: 1px;
  background: #d94b2a;
  vertical-align: middle;
  margin: 0 1rem;
  opacity: 0.4;
}

@keyframes nnFadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section-mp9nehth .nn-text-accent {
  color: #d94b2a;
  font-style: italic;
}

@media (max-width: 767px) {
  .section-mp9nehth {
    padding: 6rem 0;
  }

  .section-mp9nehth .nn-testimonials__title {
    font-size: 3rem;
  }

  .section-mp9nehth .nn-testimonial__text {
    font-size: 1.8rem;
  }
}
</style>
{% endheader %}

<section class="section-mp9nehth" id="testimonials">
  <div class="container">
    <div class="row">
      <div class="col-md-12 text-center">
        {% if this.Model.section_label %}
        <h6 class="nn-section-label" property="true" data-property="section_label" method="text">{{this.Model.section_label}}</h6>
        {% endif %}
        {% if this.Model.title %}
        <h2 class="nn-testimonials__title" property="true" data-property="title" method="html">{{this.Model.title | raw}}</h2>
        {% endif %}
      </div>
    </div>

    {% if this.Model.testimonials %}
    <div class="row">
      <div class="col-md-10 col-md-offset-1">
        <div class="nn-testimonials__carousel" id="testimonialCarousel">
          {% assign testimonial_index = forloop.index0 %}
          {% for testimonial in this.Model.testimonials %}
          <div class="nn-testimonial {% if forloop.first %}active{% endif %}">
            <div class="nn-testimonial__quote-mark">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
              </svg>
            </div>
            {% if testimonial.quote %}
            <p class="nn-testimonial__text" property="true" data-property="testimonials[{{forloop.index0}}].quote" method="text">{{testimonial.quote}}</p>
            {% endif %}
            <div class="nn-testimonial__author">
              {% if testimonial.author_avatar %}
              <img property="true" data-property="testimonials[{{forloop.index0}}].author_avatar" method="attr" para="src" src="{% url testimonial.author_avatar %}" alt="{{testimonial.author_name}}" class="nn-testimonial__avatar" loading="lazy">
              {% endif %}
              <div>
                {% if testimonial.author_name %}
                <strong class="nn-testimonial__name" property="true" data-property="testimonials[{{forloop.index0}}].author_name" method="text">{{testimonial.author_name}}</strong>
                {% endif %}
                {% if testimonial.author_role %}
                <span class="nn-testimonial__role" property="true" data-property="testimonials[{{forloop.index0}}].author_role" method="text">{{testimonial.author_role}}</span>
                {% endif %}
              </div>
            </div>
          </div>
          {% endfor %}

          <div class="nn-testimonials__controls">
            <button class="nn-testimonials__btn" id="testimonialPrev" aria-label="Previous">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </button>
            <div class="nn-testimonials__dots" id="testimonialDots">
              {% for testimonial in this.Model.testimonials %}
              <span class="{% if forloop.first %}active{% endif %}"></span>
              {% endfor %}
            </div>
            <button class="nn-testimonials__btn" id="testimonialNext" aria-label="Next">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
</section>

{% footer %}
<script type="text/javascript">
(function() {
  var section = document.querySelector('.section-mp9nehth');
  if (!section) return;
  var testimonials = section.querySelectorAll('.nn-testimonial');
  var dots = section.querySelectorAll('.nn-testimonials__dots span');
  var prevBtn = section.querySelector('#testimonialPrev');
  var nextBtn = section.querySelector('#testimonialNext');
  var currentTestimonial = 0;

  if (!testimonials.length) return;

  function showTestimonial(index) {
    testimonials.forEach(function(t) { t.classList.remove('active'); });
    dots.forEach(function(d) { d.classList.remove('active'); });
    testimonials[index].classList.add('active');
    dots[index].classList.add('active');
    currentTestimonial = index;
  }

  var autoInterval = setInterval(function() {
    var next = (currentTestimonial + 1) % testimonials.length;
    showTestimonial(next);
  }, 6000);

  function resetAutoInterval() {
    clearInterval(autoInterval);
    autoInterval = setInterval(function() {
      var n = (currentTestimonial + 1) % testimonials.length;
      showTestimonial(n);
    }, 6000);
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      var prev = (currentTestimonial - 1 + testimonials.length) % testimonials.length;
      showTestimonial(prev);
      resetAutoInterval();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      var next = (currentTestimonial + 1) % testimonials.length;
      showTestimonial(next);
      resetAutoInterval();
    });
  }

  dots.forEach(function(dot, idx) {
    dot.addEventListener('click', function() {
      showTestimonial(idx);
      resetAutoInterval();
    });
  });
})();
</script>
{% endfooter %}
